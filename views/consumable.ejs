$('#addItemForm').on('submit', function (e) {
  e.preventDefault();
  e.stopPropagation();

  var form = this;
  var formData = $(form).serialize();

  Swal.fire({
    title: 'Are you sure?',
    text: 'Do you want to add this consumable item?',
    icon: 'question',
    showCancelButton: true,
    confirmButtonColor: '#0F828C',
    cancelButtonColor: '#d33',
    confirmButtonText: 'Yes, add it!',
    cancelButtonText: 'Cancel'
  }).then((result) => {

    if (result.isConfirmed) {

      $.ajax({
        url: apiUrl + '/consumable/insertConsumables',
        method: 'POST',
        data: formData,
        beforeSend: function () {
          Swal.fire({
            title: 'Saving...',
            text: 'Please wait while we add the item.',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            }
          });
        },
        success: function (response) {
          Swal.fire({
            icon: 'success',
            title: 'Item Added',
            text: 'The consumable item has been added successfully.',
            confirmButtonColor: '#0F828C'
          });

          form.reset();
          closeModal();

          // Reload DataTable if needed
          $('#consumablesTable').DataTable().ajax.reload();
        },
        error: function () {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'An error occurred while adding the item. Please try again.',
            confirmButtonColor: '#0F828C'
          });
        }
      });

    }

  });
});

$('#consumablesTable').DataTable({
          serverSide: true,
          processing: true,
          ajax: {
            url: apiUrl + '/consumable/showConsumables',
            type: 'POST',
            dataType: 'json'
          },
          columns: [
            { data: 'item' },
            { data: 'item_classification' },
            { data: 'current_stock' },
            { data: 'stock_no' },
            { data: 'date_of_entry' },
            { data: 'date_of_purchase' },
            { data: 'brand' },
            { data: 'model' },
            { data: 'batch_number'},
            {
              data: 'stock_no',
              render: function (data, type, row) {
                return `
                  <button class="add-request bg-white border-2 border-yellow-500 text-yellow-500 hover:bg-yellow-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${row.id}" title="Add">
                    <i class="fas fa-plus"></i> Add
                  </button>
                  <button class="edit-btn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${row.id}" title="Edit">
                    <i class="fas fa-edit"></i> Edit
                  </button>
                  <button class="delete-btn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${row.id}" title="Delete">
                    <i class="fas fa-trash"></i> Delete
                  </button>
                `;
              }
            }
          ]
        });

        $('#consumablesTable').on('click', '.edit-btn', function () {
          const id = $(this).data('id');
          editItemId = id;
          const rowData = $('#consumablesTable').DataTable().row($(this).parents('tr')).data();
          
          $('#item').val(rowData.item || '');
          $('#item_classification').val(rowData.item_classification || '');
          $('#starting_stock').val(rowData.current_stock || '');
          $('#date_of_purchase').val(formatDateForInput(rowData.date_of_purchase));
          $('#brand').val(rowData.brand || '');
          $('#model').val(rowData.model || '');
          $('#batch_number').val(rowData.batch_number || '');
          
          openAddItemModal(true);
        });

        $('#consumablesTable tbody').on('click', '.add-request', function () {

          const rowData = $('#consumablesTable').DataTable().row($(this).parents('tr')).data();

          requestsTable.row.add([
            rowData.item,
            "Pending",
            new Date().toLocaleDateString(),
            `<input type="number" class="issued-qty border rounded px-2 py-1 w-20" value="1" min="1">`,
          
            rowData.item_classification,
            rowData.brand,
            rowData.model,
            rowData.stock_no,
            rowData.batch_number || '',
            '<input type="text" class="issued-to border rounded px-2 py-1 w-32" placeholder="Enter section/office">',
            `<button class="remove-btn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" title="Remove">
              <i class="fas fa-times"></i> Remove
            </button>`
          ]).draw();

        });

        $('#recordRequestBtn').click(function () {

          let requestItems = [];

          $('#requestsTable tbody tr').each(function () {

            let item = $(this).find('td:eq(0)').text();
            let status = $(this).find('td:eq(1)').text();
            let transaction_date = $(this).find('td:eq(2)').text();
            let quantity = $(this).find('.issued-qty').val();
            let classification = $(this).find('td:eq(4)').text();
            let brand = $(this).find('td:eq(5)').text();
            let model = $(this).find('td:eq(6)').text();
            let stock_no = $(this).find('td:eq(7)').text();
            let batch_number = $(this).find('td:eq(8)').text();
            let issued_to = $(this).find('.issued-to').val();

            requestItems.push({
              item: item,
              status: status,
              transaction_date: transaction_date,
              issued_quantity: quantity,
              item_classification: classification,
              brand: brand,
              model: model,
              stock_no: stock_no,
              batch_number: batch_number,
              issued_to: issued_to
            });

          });

          console.log(requestItems);

         $.ajax({
            url: apiUrl + '/consumable/recordRequest',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ items: requestItems }),

            success: function (response) {
              Swal.fire({
                icon: 'success',
                title: 'Request Recorded',
                text: 'The request has been saved successfully.'
              });

              requestsTable.clear().draw();
            },

            error: function () {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to record request.'
              });
            }

          });

        });

        $('#requestsTable tbody').on('click', '.remove-btn', function () {
            requestsTable.row($(this).parents('tr')).remove().draw();
          });
     });
  </script>