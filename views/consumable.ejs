<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Consumables - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- DataTables -->
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="shortcut icon" type="image/png" href="/Images/ndh-it.png?v=1">
</head>

<body class="bg-gray-100 overflow-x-hidden">
  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'consumable', baseUrl: baseUrl, accessLevel: accessLevel }) %>

      <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden"
        style="min-width: 0; max-width: 100%;">
        <!-- Page Header -->
        <div class="mb-6">
          <h1 style="color: #0F828C;" class="text-4xl font-bold mb-2">Consumable Page</h1>
          <p class="text-gray-600">Manage consumable items and requests</p>
        </div>
        <!-- Button Container -->
        <div class="flex justify-end mb-4">
          <% if (isAdmin) { %>
            <button id="ConsumableLogsBtn"
              class="bg-gradient-to-r from-[#2e5558] to-[#0F828C] hover:from-[#0F828C] hover:to-[#2e5558] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-history text-lg"></i>
              <span class="font-semibold">Consumable Logs</span>
            </button>
            <button id="AddItemBtn"
              class="ml-4 bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-plus text-lg"></i>
              <span class="font-semibold">Add Item</span>
            </button>
            <button id="openInactiveConsumablesModal" class="ml-4 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-600 text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-red-600 focus:ring-opacity-50">
              <i class="fas fa-ban text-lg"></i>
              <span class="font-semibold">Inactive</span>
            </button>
          <% } %>
        </div>
        <!-- Consumables Inventory Table -->
        <div class="mb-8">
          <div class="bg-white rounded-lg shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Consumables Inventory</h2>
            <div class="w-full overflow-x-auto">
              <table id="consumablesTable" class="display nowrap" style="width:100%">
                <thead style="background-color: #0F828C;">
                  <tr>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Item</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Classification</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Current Stock</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Stock No</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Date of Entry</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Date of Purchase</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Brand</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Model</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Batch Number</th>
                    <% if (isAdmin) { %>
                      <th
                        class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                        Actions</th>
                    <% } %>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <% if (isAdmin) { %>
        <!-- Request Inventory Table -->
        <div class="mb-8">
          <div class="bg-white rounded-lg shadow-lg p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Request Inventory</h2>
            <div class="w-full overflow-x-auto">
              <table id="requestsTable" class="display nowrap" style="width:100%">
                <thead style="background-color: #0F828C;">
                  <tr>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Item</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Item Status</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Transaction Date</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Issued Quantity</th>
               
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Item Classification</th>

                      <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Brand</th>

                      <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Model</th>

                    <th
                    
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Stock No</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Batch Number</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Issued To:</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Current Stock:</th>
                    <th
                      class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                      Action</th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                </tbody>
              </table>
            </div>

            <!-- Record Request Button -->
            <div class="mt-6 flex justify-end">
              <button id="recordRequestBtn"
                class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50 font-semibold">
                Record Request
              </button>
            </div>
          </div>
        </div>
        <% } %>
      </main>
  </div>

  <% if (isAdmin) { %>
  <!-- Add Item Modal -->
  <div id="addItemModal" class="fixed inset-0 z-50 hidden">
    <div id="addItemModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-4xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Add Consumable Item</h2>
          <button id="closeAddItemModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="addItemForm" class="px-6 py-6">
          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="item" class="block text-sm font-medium text-gray-700 mb-2">Item</label>
                <input id="item" name="item" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="item_classification" class="block text-sm font-medium text-gray-700 mb-2">Item Classification</label>
                <select id="item_classification" name="item_classification"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="">Select classification...</option>
                  <option value="Ink">Ink</option>
                  <option value="IT Consumables">IT Consumables</option>
                  <option value="Office Supplies">Office Supplies</option>
                  <option value="Cleaning Supplies">Cleaning Supplies</option>
                  <option value="Pantry Items">Pantry Items</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="stock" class="block text-sm font-medium text-gray-700 mb-2"> Starting Stock</label>
                <input type="number" id="starting_stock" name="starting_stock" min="0"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="date_of_purchase" class="block text-sm font-medium text-gray-700 mb-2">Date of Purchase</label>
                <input id="date_of_purchase" name="date_of_purchase" type="date"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>

             
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="brand" class="block text-sm font-medium text-gray-700 mb-2">Brand</label>
                <input id="brand" name="brand" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="model" class="block text-sm font-medium text-gray-700 mb-2">Model</label>
                <input id="model" name="model" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>

             
            </div>
          </section>

          <section class="mb-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="batch_number" class="block text-sm font-medium text-gray-700 mb-2">Batch Number</label>
                <input id="batch_number" name="batch_number" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>

              <div>
                <label for="date_of_delivery" class="block text-sm font-medium text-gray-700 mb-2">Date of Delivery</label>
                <input id="date_of_delivery" name="date_of_delivery" type="date"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <div class="flex items-center gap-4">
            <button type="submit"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-plus text-lg"></i>
              <span class="font-semibold">Add Item</span>
            </button>

            <button id="clearAddItemForm" type="button"
              class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
              Clear Form
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Consumable Logs Modal -->
  <div id="consumableLogsModal" class="fixed inset-0 z-50 hidden">
    <div id="logsModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-7xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Consumable Transaction Logs</h2>
          <button id="closeLogsModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <div class="px-6 py-6">
          <div class="w-full overflow-x-auto">
            <table id="logsTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Item</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Transaction Date</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Issued Quantity</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Item Classification</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Stock No</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Batch Number</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Issued To</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">
                    Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="inactiveConsumablesModal" class="fixed inset-0 z-50 hidden">
    <div id="inactiveConsumablesModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-5xl rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Inactive Consumables</h2>
          <button id="closeInactiveConsumablesModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <div class="px-6 py-6">
          <div class="overflow-x-auto">
            <table id="inactiveConsumablesTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Classification</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Brand</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Model</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Return Form Modal -->
  <div id="returnFormModal" class="fixed inset-0 hidden" style="z-index: 60;">
    <div id="returnModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-3xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Return Form</h2>
          <button id="closeReturnModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="returnForm" class="px-6 py-6">
          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="return_transaction_id" class="block text-sm font-medium text-gray-700 mb-2">Transaction ID</label>
                <input id="return_transaction_id" type="text" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
              <div>
                <label for="return_item" class="block text-sm font-medium text-gray-700 mb-2">Item</label>
                <input id="return_item" type="text" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="return_stock_no" class="block text-sm font-medium text-gray-700 mb-2">Stock No</label>
                <input id="return_stock_no" type="text" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
              <div>
                <label for="return_batch_number" class="block text-sm font-medium text-gray-700 mb-2">Batch Number</label>
                <input id="return_batch_number" type="text" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="return_issued_to" class="block text-sm font-medium text-gray-700 mb-2">Issued To</label>
                <input id="return_issued_to" type="text" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
              <div>
                <label for="return_issued_quantity" class="block text-sm font-medium text-gray-700 mb-2">Issued Quantity</label>
                <input id="return_issued_quantity" type="number" readonly
                  class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-gray-600 focus:outline-none">
              </div>
            </div>
          </section>

          <section class="mb-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
             <!-- <div>
                <label for="return_quantity" class="block text-sm font-medium text-gray-700 mb-2">Return Quantity</label>
                <input id="return_quantity" name="return_quantity" type="number" min="1"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter return quantity">
              </div>-->
              <div>
                <label for="return_quantity" class="block text-sm font-medium text-gray-700 mb-2">Return Quantity</label>
                <input id="return_quantity" name="return_quantity" type="number" min="0"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter return quantity">
              </div>
            </div>
          </section>

          <div class="flex items-center gap-4">
            <button id="submitReturnForm" type="button"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-reply text-lg"></i>
              <span class="font-semibold">Submit Return</span>
            </button>

            <button id="cancelReturnForm" type="button"
              class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <% } %>

</body>

</html>


  <script>

    $(document).ready(function () {

      const apiUrl = "<%= baseUrl %>";
      const isAdminUser = JSON.parse('<%- JSON.stringify(!!isAdmin) %>');

 
        // Modal functionality (Admin only)
        const addItemModal = $('#addItemModal');
        const addItemBtn = $('#AddItemBtn');
        const closeModalBtn = $('#closeAddItemModal');
        const modalBackdrop = $('#addItemModalBackdrop');
        const clearFormBtn = $('#clearAddItemForm');
        const inactiveConsumablesModal = $('#inactiveConsumablesModal');
