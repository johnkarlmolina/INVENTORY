            infoEmpty: 'Showing 0 to 0 of 0 entries',
            infoFiltered: '(filtered from _MAX_ total entries)',
            zeroRecords: 'No matching records found',
            emptyTable: 'No data available in table',
            paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
          }
        });*/

        // Request Inventory DataTable 
        const requestsTable = new DataTable('#requestsTable', {
          pageLength: 10,
          ordering: true,
          searching: true,
          info: true,
          scrollX: true,
          scrollCollapse: true,
          responsive: false,
          autoWidth: false,
          columnDefs: [
            { width: '180px', targets: 0 },  // Item
            { width: '120px', targets: 1 },  // Item Status
            { width: '150px', targets: 2 },  // Transaction Date
            { width: '150px', targets: 3 },  // Transaction Quantity
            { width: '140px', targets: 4 },  // blank
            { width: '140px', targets: 5 },  // Item Classification
            { width: '100px', targets: 6 },  // Brand
            { width: '100px', targets: 7 },  // Model
            { width: '100px', targets: 8 },  // Stock No
            { width: '120px', targets: 9 },  // Batch Number
            { width: '80px', targets: 10, className: 'text-center' }  // Remove
          ],
          language: {
            search: 'Search:',
            lengthMenu: 'Show _MENU_ entries',
            info: 'Showing _START_ to _END_ of _TOTAL_ entries',
            infoEmpty: 'Showing 0 to 0 of 0 entries',
            infoFiltered: '(filtered from _MAX_ total entries)',
