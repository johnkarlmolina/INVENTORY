$('#addItemForm').on('submit', function (e) {
  e.preventDefault();
  e.stopPropagation();

  var form = this;
  var formData = $(form).serializeArray();
  var dataObject = {};
  
  // Convert form data array to object
  $.each(formData, function() {
    dataObject[this.name] = this.value;
  });

  // Determine if we're in edit mode
  var url, confirmText, successTitle, successText, loadingText;
  
  if (isEditMode) {
    url = apiUrl + '/consumable/updateConsumable';
    confirmText = 'Do you want to update this consumable item?';
    successTitle = 'Item Updated';
    successText = 'The consumable item has been updated successfully.';
    loadingText = 'Please wait while we update the item.';
    dataObject.stock_no = editItemId;  // Add stock_no for update
    dataObject.current_stock = dataObject.starting_stock;  // Use starting_stock as current_stock for update
  } else {
    url = apiUrl + '/consumable/insertConsumables';
    confirmText = 'Do you want to add this consumable item?';
    successTitle = 'Item Added';
    successText = 'The consumable item has been added successfully.';
    loadingText = 'Please wait while we add the item.';
  }

  Swal.fire({
    title: 'Are you sure?',
    text: confirmText,
    icon: 'question',
    showCancelButton: true,
    confirmButtonColor: '#0F828C',
    cancelButtonColor: '#d33',
    confirmButtonText: isEditMode ? 'Yes, update it!' : 'Yes, add it!',
    cancelButtonText: 'Cancel'
  }).then((result) => {

    if (result.isConfirmed) {

      $.ajax({
        url: url,
        method: 'POST',
        data: dataObject,
        beforeSend: function () {
          Swal.fire({
            title: 'Saving...',
            text: loadingText,
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            }
          });
        },
        success: function (response) {
          Swal.fire({
            icon: 'success',
            title: successTitle,
            text: successText,
            confirmButtonColor: '#0F828C'
          });

          form.reset();
          closeModal();

          // Reload DataTable
          consumablesTable.ajax.reload();
        },
        error: function () {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'An error occurred while saving the item. Please try again.',
            confirmButtonColor: '#0F828C'
          });
        }
      });

    }

  });
});

