          });
        });

          $(document).on('change', '.issued-qty', function () {
            const value = Number($(this).val()) || 0;
            const max = Number($(this).closest('tr').find('td:eq(10)').text()) || 0;
            if (value < 1) {
              $(this).val(1);
            } else if (value > max) {
              swal.fire({
                icon: 'warning',
                title: 'Invalid Quantity',
                text: `Issued quantity cannot exceed current stock (${max}).`
              }).then(() => {
                $(this).val(max);
              });
            }
            
            
          });
     });
  </script>