<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="icon" type="image/png" href="/Images/ndh-it.png">
</head>
<body class="bg-gray-100 overflow-x-hidden">
  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'user-management' }) %>

     <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden" style="min-width: 0; max-width: 100%;">
      <div class="mb-6">
        <h1 style="color: #0F828C;" class="text-4xl font-bold mb-2">User Management</h1>
        <p class="text-gray-600">Manage system users and access records</p>
      </div>

      <div class="flex justify-end gap-3 mb-4">
        <button id="addNewUserBtn"
          class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
          <i class="fas fa-plus text-lg"></i>
          <span class="font-semibold">Add New User</span>
        </button>
      </div>

      <div class="mb-8">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h2 class="text-xl font-semibold text-gray-800 mb-4">User Records</h2>
          <div class="w-full overflow-x-auto">
            <table id="userManagementTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">User ID</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Full Name</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Department</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Username</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Access Level</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Time Encoding</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div id="addUserModal" class="fixed inset-0 z-50 hidden">
    <div id="addUserModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-3xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Add New User</h2>
          <button id="closeAddUserModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="addUserForm" class="px-6 py-6">
          <section class="mb-6">
            <div class="grid grid-cols-1 gap-4">
              <div>
                <label for="full_name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                <input id="full_name" name="full_name" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter full name">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!--<div>
                <label for="department" class="block text-sm font-medium text-gray-700 mb-2">Department</label>
                <input id="department" name="department" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter department">
              </div>-->
              <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-2">Username</label>
                <input id="username" name="username" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter username">
              </div>

               <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                <input id="password" name="password" type="password"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter password">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="access_level" class="block text-sm font-medium text-gray-700 mb-2">Access Level</label>
                <select id="access_level" name="access_level"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="">Select access level...</option>
                  <option value="Admin">Admin</option>
                  <option value="Staff">Staff</option>
                  <option value="Viewer">Viewer</option>
                </select>
              </div>
              <div>
                <label for="department" class="block text-sm font-medium text-gray-700 mb-2">Department</label>
                <input id="department" name="department" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter department">
              </div>
            </div>
          </section>

          <div class="flex items-center gap-4">
            <button type="submit"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-user-plus text-lg"></i>
              <span class="font-semibold">Save User</span>
            </button>

            <button id="cancelAddUserBtn" type="button"
              class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
              Cancel
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    $(document).ready(function () {
      const apiUrl = "<%= baseUrl %>";
      const actionButtons = `
        <div class="flex items-center gap-2">
          <button class="edit-user-btn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" type="button" title="Edit">
            <i class="fas fa-edit"></i> Edit
          </button>
          <button class="delete-user-btn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" type="button" title="Delete">
            <i class="fas fa-trash"></i> Delete
          </button>
        </div>
      `;

      $('#userManagementTable').DataTable({
        data: [
          ['--', '--', '--', '--', '--', '--', actionButtons],
          ['--', '--', '--', '--', '--', '--', actionButtons],
          ['--', '--', '--', '--', '--', '--', actionButtons],
          ['--', '--', '--', '--', '--', '--', actionButtons]
        ],
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        columnDefs: [
          { width: '120px', targets: 0 },
          { width: '220px', targets: 1 },
          { width: '180px', targets: 2 },
          { width: '180px', targets: 3 },
          { width: '160px', targets: 4 },
          { width: '180px', targets: 5 },
          { width: '220px', targets: 6, orderable: false }
        ],
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No data available in table',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
      });

      const addUserModal = $('#addUserModal');
      const addUserModalBackdrop = $('#addUserModalBackdrop');
      const closeAddUserModalBtn = $('#closeAddUserModal');
      const cancelAddUserBtn = $('#cancelAddUserBtn');

      function openAddUserModal() {
        addUserModal.removeClass('hidden');
        $('body').css('overflow', 'hidden');
      }

      function closeAddUserModal() {
        addUserModal.addClass('hidden');
        $('#addUserForm')[0].reset();
        $('body').css('overflow', '');
      }

      $('#addNewUserBtn').on('click', openAddUserModal);
      closeAddUserModalBtn.on('click', closeAddUserModal);
      addUserModalBackdrop.on('click', closeAddUserModal);
      cancelAddUserBtn.on('click', closeAddUserModal);

  $('#addUserForm').on('submit', function (e) {
  e.preventDefault();

  var form = $(this);

  Swal.fire({
    title: 'Are you sure?',
    text: 'Do you want to add this user?',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Yes, add user!',
    cancelButtonText: 'Cancel'
  }).then((result) => {
    if (result.isConfirmed) {

      $.ajax({
        url: apiUrl + '/user-management/addUser',
        method: 'POST',
        data: form.serialize(),

        success: function (response) {
          Swal.fire({
            icon: 'success',
            title: 'User Added',
            text: 'The new user has been added successfully.'
          });

          console.log(form.serialize());
          closeAddUserModal();
        },

        error: function (xhr, status, error) {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'An error occurred while adding the user. Please try again.'
          });
        }

      });

    }
  });
});

      $(document).on('click', '.edit-user-btn', function () {
        Swal.fire({
          icon: 'info',
          title: 'UI Only',
          text: 'Edit action is not connected yet.'
        });
      });

      $(document).on('click', '.delete-user-btn', function () {
        Swal.fire({
          icon: 'info',
          title: 'UI Only',
          text: 'Delete action is not connected yet.'
        });
      });
    });
  </script>
</body>
</html>