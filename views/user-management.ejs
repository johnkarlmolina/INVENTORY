<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="icon" type="image/png" href="/Images/ndh-it.png">

  <style>
    /* Hide DataTables' default processing overlay; we use a skeleton loader instead. */
    .dt-processing {
      display: none !important;
    }
  </style>
</head>
<body class="bg-gray-100 overflow-x-hidden">
  <!-- Page Skeleton Loader (initial page/data load) - main content only (keeps sidebar visible) -->
  <div id="pageSkeleton" class="fixed inset-0 z-[60] hidden pointer-events-none">
    <div id="pageSkeletonContent" class="h-full bg-gray-100 overflow-auto">
      <main class="p-8" style="min-width: 0; max-width: 100%;">
      <div class="animate-pulse">
        <div class="mb-6">
          <div class="h-10 w-80 bg-gray-200 rounded mb-3"></div>
          <div class="h-5 w-72 bg-gray-200 rounded"></div>
        </div>
        <div class="flex justify-end mb-4 gap-4">
          <div class="h-12 w-44 bg-gray-200 rounded-xl"></div>
          <div class="h-12 w-32 bg-gray-200 rounded-xl"></div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto">
          <div class="h-6 w-48 bg-gray-200 rounded mb-4"></div>
          <div class="space-y-3">
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
          </div>
        </div>
      </div>
      </main>
    </div>
  </div>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'user-management', baseUrl: baseUrl, accessLevel: accessLevel }) %>

     <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden" style="min-width: 0; max-width: 100%;">
      <div class="mb-6">
        <h1 style="color: #0F828C;" class="text-4xl font-bold mb-2">User Management</h1>
        <p class="text-gray-600">Manage system users and access records</p>
      </div>

      <div class="flex justify-end mb-4">
        <% if (isAdmin) { %>
          <button id="addNewUserBtn"
            class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
            <i class="fas fa-plus text-lg"></i>
            <span class="font-semibold">Add New User</span>
          </button>
          <button id="openInactiveUsersModal" class="ml-4 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-600 text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-red-600 focus:ring-opacity-50">
            <i class="fas fa-ban text-lg"></i>
            <span class="font-semibold">Inactive</span>
          </button>
        <% } %>
      </div>

      <div class="mb-8">
        <div class="bg-white rounded-lg shadow-lg p-6 relative" id="userManagementTableCard" aria-busy="true">
          <h2 class="text-xl font-semibold text-gray-800 mb-4">User Records</h2>
          <!-- Skeleton Loader (shown while DataTables is fetching) -->
          <div id="userManagementSkeleton" class="absolute inset-0 z-10 bg-white/80 backdrop-blur-[1px] rounded-lg">
            <div class="p-6 animate-pulse">
              <div class="flex items-center justify-between mb-6">
                <div class="h-6 w-56 bg-gray-200 rounded"></div>
                <div class="h-9 w-40 bg-gray-200 rounded"></div>
              </div>
              <div class="space-y-3">
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
              </div>
            </div>
          </div>

          <div class="w-full overflow-x-auto opacity-0" id="userManagementTableHost">
            <table id="userManagementTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">User ID</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Full Name</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Department</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Username</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Password</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Access Level</th>
                  <% if (isAdmin) { %>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                  <% } %>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <% if (isAdmin) { %>
  <div id="addUserModal" class="fixed inset-0 z-50 hidden">
    <div id="addUserModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-3xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 id="addUserModalTitle" class="text-2xl font-bold" style="color: #0F828C;">Add New User</h2>
          <button id="closeAddUserModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="addUserForm" class="px-6 py-6" novalidate>
          <input id="user_no" name="user_no" type="hidden">
          <section class="mb-6">
            <div class="grid grid-cols-1 gap-4">
              <div>
                <label for="full_name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                <input id="full_name" name="full_name" type="text" required
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter full name">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!--<div>
                <label for="department" class="block text-sm font-medium text-gray-700 mb-2">Department</label>
                <input id="department" name="department" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter department">
              </div>-->
              <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-2">Username</label>
                <input id="username" name="username" type="text" required
                  aria-describedby="usernameHelp"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter username">
                <p id="usernameHelp" class="mt-1 text-xs text-gray-500">
                  3-20 characters, alphanumeric and underscore only
                </p>
              </div>

               <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                <input id="password" name="password" type="password" required
                    aria-describedby="passwordHelp"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter password">
                  <p id="passwordHelp" class="mt-1 text-xs text-gray-500">
                    Min 8 chars, 1 uppercase, 1 number. Leave blank to keep current when editing
                  </p>
                  <div id="passwordStrengthWrap" class="mt-2 hidden" aria-live="polite">
                    <div id="passwordStrengthBar" class="flex gap-2" aria-hidden="true">
                      <div data-seg="1" class="h-1 flex-1 rounded bg-gray-200"></div>
                      <div data-seg="2" class="h-1 flex-1 rounded bg-gray-200"></div>
                      <div data-seg="3" class="h-1 flex-1 rounded bg-gray-200"></div>
                      <div data-seg="4" class="h-1 flex-1 rounded bg-gray-200"></div>
                    </div>
                    <p id="passwordStrengthLabel" class="mt-1 text-xs text-gray-500"></p>
                  </div>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="access_level" class="block text-sm font-medium text-gray-700 mb-2">Access Level</label>
                <select id="access_level" name="access_level" required
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="">Select access level...</option>
                  <option value="Admin">Admin</option>
                  <option value="IT Technician">IT Technician</option>
                </select>
              </div>
              <div>
                <label for="department" class="block text-sm font-medium text-gray-700 mb-2">Department</label>
                <input id="department" name="department" type="text" required
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20"
                  placeholder="Enter department">
              </div>
            </div>
          </section>

          <% if (isAdmin) { %>
            <div class="flex items-center gap-4">
              <button id="saveUserBtn" type="submit"
                class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
                <i id="saveUserBtnIcon" class="fas fa-user-plus text-lg"></i>
                <span id="saveUserBtnText" class="font-semibold">Save User</span>
              </button>

              <button id="cancelAddUserBtn" type="button"
                class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
                Cancel
              </button>
            </div>
          <% } %>
        </form>
      </div>
    </div>
  </div>

  <div id="inactiveUsersModal" class="fixed inset-0 z-50 hidden">
    <div id="inactiveUsersModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-5xl rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Inactive Users</h2>
          <button id="closeInactiveUsersModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <div class="px-6 py-6">
          <div class="overflow-x-auto">
            <table id="inactiveUsersTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Name</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Username</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% } %>

  <script>
    $(document).ready(function () {
      const apiUrl = "<%= baseUrl %>";
      const isAdminUser = JSON.parse('<%- JSON.stringify(!!isAdmin) %>');

      // Page/table skeleton helpers
      const $pageSkeleton = $('#pageSkeleton');
      let initialLoadComplete = false;
      function syncPageSkeletonOffset() {
        const mainEl = document.querySelector('main');
        const contentEl = document.getElementById('pageSkeletonContent');
        if (!mainEl || !contentEl) return;
        const ml = window.getComputedStyle(mainEl).marginLeft;
        contentEl.style.marginLeft = ml;
      }

      function showPageSkeleton() {
        syncPageSkeletonOffset();
        $pageSkeleton.removeClass('hidden');
        $('body').attr('aria-busy', 'true');
      }
      function hidePageSkeleton() {
        $pageSkeleton.addClass('hidden');
        $('body').attr('aria-busy', 'false');
      }

      window.addEventListener('resize', syncPageSkeletonOffset);

      const $userSkeleton = $('#userManagementSkeleton');
      const $userHost = $('#userManagementTableHost');
      const $userCard = $('#userManagementTableCard');
      function showUserSkeleton() {
        $userSkeleton.removeClass('hidden');
        $userHost.addClass('opacity-0');
        $userCard.attr('aria-busy', 'true');
      }
      function hideUserSkeleton() {
        $userSkeleton.addClass('hidden');
        $userHost.removeClass('opacity-0');
        $userCard.attr('aria-busy', 'false');
      }

      // Start in loading state until the first DataTables response arrives.
      showPageSkeleton();
      showUserSkeleton();
      const renderActionButtons = (id) => `
        <div class="flex items-center gap-2">
          <button class="edit-user-btn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" type="button" title="Edit">
            <i class="fas fa-edit"></i> Edit
          </button>
          <button class="delete-user-btn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" type="button" title="Delete">
            <i class="fas fa-trash"></i> Delete
          </button>
        </div>
      `;

      const userColumns = [
        { data: 'user_no' },
        { data: 'fname' },
        { data: 'department' },
        { data: 'uname' },
        { data: 'upassword' },
        {
          data: 'access_lvl',
          render: function (val) {
            return val === 'Staff' ? 'IT Technician' : (val ?? '');
          }
        }
      ];
      if (isAdminUser) {
        userColumns.push({
          data: 'user_no',
          orderable: false,
          searchable: false,
          render: function (id) {
            return renderActionButtons(id);
          }
        });
      }

      const userColumnDefs = [
        { width: '120px', targets: 0 },
        { width: '220px', targets: 1 },
        { width: '180px', targets: 2 },
        { width: '180px', targets: 3 },
        { width: '160px', targets: 4 },
        { width: '160px', targets: 5 }
      ];
      if (isAdminUser) {
        userColumnDefs.push({ width: '220px', targets: 6, orderable: false });
      }

      const userTable = new DataTable('#userManagementTable', {
        processing: true,
        serverSide: true,
        ajax: {
          url: apiUrl + '/user-management/userDataTable',
          type: 'POST',
          dataType: 'json'
        },
        columns: userColumns,
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        columnDefs: userColumnDefs,
        initComplete: function () {
          hideUserSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        },
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No data available in table',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
      });

      // Toggle skeleton during server-side DataTables AJAX requests
      if (userTable && typeof userTable.on === 'function') {
        userTable.on('preXhr', function () {
          if (!initialLoadComplete) {
            showPageSkeleton();
          } else {
            showUserSkeleton();
          }
        });
        userTable.on('xhr', function () {
          hideUserSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
        userTable.on('error', function () {
          hideUserSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
      }

      const addUserModal = $('#addUserModal');
      const inactiveUsersModal = $('#inactiveUsersModal');
      const addUserForm = $('#addUserForm');
      const addUserModalBackdrop = $('#addUserModalBackdrop');
      const inactiveUsersModalBackdrop = $('#inactiveUsersModalBackdrop');
      const closeAddUserModalBtn = $('#closeAddUserModal');
      const closeInactiveUsersModalBtn = $('#closeInactiveUsersModal');
      const cancelAddUserBtn = $('#cancelAddUserBtn');
      const addUserModalTitle = $('#addUserModalTitle');
      const saveUserBtnIcon = $('#saveUserBtnIcon');
      const saveUserBtnText = $('#saveUserBtnText');
      let isEditMode = false;
      let editUserId = null;

      function evaluatePasswordStrength(password) {
          const value = String(password || '');
        if (value.trim() === '') return { label: '', colorClass: 'text-gray-500', fillClass: 'bg-gray-200', score: 0 };

          const hasUpper = /[A-Z]/.test(value);
          const hasLower = /[a-z]/.test(value);
          const hasNumber = /\d/.test(value);
          const hasSymbol = /[^A-Za-z0-9]/.test(value);
          const length = value.length;

          // Must meet the policy first, otherwise it's Weak.
          if (length < 8 || !hasUpper || !hasNumber) {
            return { label: 'Weak', colorClass: 'text-red-600', fillClass: 'bg-red-500', score: 1 };
          }

          // Meets your policy => at least Fair.
          const isStrong = length >= 12 && hasUpper && hasLower && hasNumber && hasSymbol;
          if (isStrong) {
            return { label: 'Strong', colorClass: 'text-green-600', fillClass: 'bg-green-500', score: 4 };
          }

          const isGood = length >= 10 && hasUpper && hasLower && hasNumber;
          if (isGood) {
            return { label: 'Good', colorClass: 'text-blue-600', fillClass: 'bg-blue-500', score: 3 };
          }

          return { label: 'Fair', colorClass: 'text-yellow-600', fillClass: 'bg-yellow-500', score: 2 };
      }

      function updatePasswordStrengthIndicator() {
        const $wrap = $('#passwordStrengthWrap');
        const $label = $('#passwordStrengthLabel');
        const $bar = $('#passwordStrengthBar');
        if (!$wrap.length || !$label.length || !$bar.length) return;

        const passwordVal = String($('#password').val() || '');

        // Blank password => plain state (hide strength UI)
        // (In edit mode, blank also means "keep current").
        if (passwordVal.trim() === '') {
          $wrap.addClass('hidden');
          $label.attr('class', 'mt-1 text-xs text-gray-500').text('');
          $bar.find('[data-seg]').each(function () {
            $(this).attr('class', 'h-1 flex-1 rounded bg-gray-200');
          });
          return;
        }

        $wrap.removeClass('hidden');

        const result = evaluatePasswordStrength(passwordVal);
        $label.attr('class', `mt-1 text-xs ${result.colorClass}`).text(result.label);

        $bar.find('[data-seg]').each(function () {
          $(this).attr('class', 'h-1 flex-1 rounded bg-gray-200');
        });

        if (result.score > 0) {
          for (let i = 1; i <= result.score; i++) {
            $bar.find(`[data-seg="${i}"]`).attr('class', `h-1 flex-1 rounded ${result.fillClass}`);
          }
        }
      }

      let inactiveUsersTable = null;
      if (isAdminUser) {
        inactiveUsersTable = new DataTable('#inactiveUsersTable', {
        processing: true,
        serverSide: true,
        ajax: {
          url: apiUrl + '/user-management/inactiveUserDataTable',
          type: 'POST',
          dataType: 'json'
        },
        columns: [
          { data: 'fname' },
          { data: 'uname' },
          {
            data: 'user_no',
            orderable: false,
            searchable: false,
            render: function (id) {
              return `
                <button class="activate-user-btn bg-green-500 border-2 border-green-500 text-white hover:bg-green-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" type="button" title="Activate">
                  <i class="fas fa-check"></i> Activate
                </button>
              `;
            }
          }
        ],
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        columnDefs: [
          { width: '220px', targets: 0 },
          { width: '180px', targets: 1 },
          { width: '160px', targets: 2, orderable: false, className: 'text-center' }
        ],
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No inactive users',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
        });
      }

      function resetUserForm() {
        addUserForm[0].reset();
        $('#user_no').val('');
        $('#password').prop('required', true).attr('placeholder', 'Enter password');
        isEditMode = false;
        editUserId = null;
        updatePasswordStrengthIndicator();
      }

      function openAddUserModal(editMode = false, rowData = null) {
        if (!isAdminUser) return;
        isEditMode = editMode;

        if (editMode && rowData) {
          editUserId = rowData.user_no;
          addUserModalTitle.text('Edit User');
          saveUserBtnIcon.removeClass('fa-user-plus').addClass('fa-save');
          saveUserBtnText.text('Update User');

          $('#user_no').val(rowData.user_no || '');
          $('#full_name').val(rowData.fname || '');
          $('#department').val(rowData.department || '');
          $('#username').val(rowData.uname || '');
          $('#password').val('').prop('required', false).attr('placeholder', 'Leave blank to keep current');
          const normalizedAccess = rowData.access_lvl === 'Staff' ? 'IT Technician' : rowData.access_lvl;
          $('#access_level').val(normalizedAccess || '');
          updatePasswordStrengthIndicator();
        } else {
          resetUserForm();
          addUserModalTitle.text('Add New User');
          saveUserBtnIcon.removeClass('fa-save').addClass('fa-user-plus');
          saveUserBtnText.text('Save User');
          updatePasswordStrengthIndicator();
        }

        addUserModal.removeClass('hidden');
        $('body').css('overflow', 'hidden');
      }

      function closeAddUserModal() {
        addUserModal.addClass('hidden');
        resetUserForm();
        addUserModalTitle.text('Add New User');
        saveUserBtnIcon.removeClass('fa-save').addClass('fa-user-plus');
        saveUserBtnText.text('Save User');
        $('body').css('overflow', '');
      }

      $('#addNewUserBtn').on('click', function () {
        if (!isAdminUser) return;
        openAddUserModal(false);
      });

      // Live password strength indicator (shows only when typing)
      $(document).on('input', '#password', updatePasswordStrengthIndicator);

      $('#openInactiveUsersModal').on('click', function () {
        if (!isAdminUser || !inactiveUsersTable) return;
        inactiveUsersModal.removeClass('hidden');
        $('body').css('overflow', 'hidden');
        inactiveUsersTable.ajax.reload(null, false);
      });

      function closeInactiveUsersModal() {
        inactiveUsersModal.addClass('hidden');
        $('body').css('overflow', '');
      }

      closeAddUserModalBtn.on('click', closeAddUserModal);
      addUserModalBackdrop.on('click', closeAddUserModal);
      cancelAddUserBtn.on('click', closeAddUserModal);
      closeInactiveUsersModalBtn.on('click', closeInactiveUsersModal);
      inactiveUsersModalBackdrop.on('click', closeInactiveUsersModal);

  $('#addUserForm').on('submit', function (e) {
  if (!isAdminUser) return;
  e.preventDefault();

  if (this.checkValidity && !this.checkValidity()) {
    if (this.reportValidity) this.reportValidity();
    Swal.fire({ icon: 'error', title: 'Missing fields', text: 'Please fill out all required fields.', confirmButtonColor: '#0F828C' });
    return;
  }

  var usernameVal = String($('#username').val() || '').trim();
  var passwordVal = String($('#password').val() || '');
  var isUpdate = isEditMode && editUserId;

  var usernameRegex = /^[A-Za-z0-9_]{3,20}$/;
  if (!usernameRegex.test(usernameVal)) {
    Swal.fire({
      icon: 'error',
      title: 'Invalid username',
      text: '3-20 characters, alphanumeric and underscore only',
      confirmButtonColor: '#0F828C'
    });
    return;
  }

  if (!isUpdate || passwordVal.trim() !== '') {
    var passwordOk = passwordVal.length >= 8 && /[A-Z]/.test(passwordVal) && /\d/.test(passwordVal);
    if (!passwordOk) {
      Swal.fire({
        icon: 'error',
        title: 'Invalid password',
        text: 'Min 8 chars, 1 uppercase, 1 number.',
        confirmButtonColor: '#0F828C'
      });
      return;
    }
  }

  var form = $(this);
  var actionText = isUpdate ? 'update' : 'add';
  var apiEndpoint = isUpdate ? apiUrl + '/user-management/updateUser' : apiUrl + '/user-management/addUser';
  var successTitle = isUpdate ? 'User Updated' : 'User Added';
  var successText = isUpdate ? 'The user has been updated successfully.' : 'The new user has been added successfully.';

  Swal.fire({
    title: 'Are you sure?',
    text: `Do you want to ${actionText} this user?`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: isUpdate ? 'Yes, update user!' : 'Yes, add user!',
    cancelButtonText: 'Cancel'
  }).then((result) => {
    if (result.isConfirmed) {

      $.ajax({
        url: apiEndpoint,
        method: 'POST',
        data: form.serialize(),

        success: function (response) {
          Swal.fire({
            icon: 'success',
            title: successTitle,
            text: response.message || successText
          });

          closeAddUserModal();
          userTable.ajax.reload(null, false);
        },

        error: function (xhr, status, error) {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'An error occurred while saving the user. Please try again.'
          });
        }

      });

    }
  });
});

      $(document).on('click', '.edit-user-btn', function () {
        if (!isAdminUser) return;
        const rowData = userTable.row($(this).closest('tr')).data();

        if (!rowData) {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'Unable to load user details for editing.'
          });
          return;
        }

        openAddUserModal(true, rowData);
      });

      $(document).on('click', '.delete-user-btn', function () {
        if (!isAdminUser) return;
        const userNo = $(this).data('id');
        const rowData = userTable.row($(this).closest('tr')).data();
        const userLabel = rowData && rowData.fname ? rowData.fname : `user #${userNo}`;

        Swal.fire({
          title: 'Delete user?',
          text: `Are you sure you want to delete ${userLabel}?`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonText: 'Yes, delete',
          confirmButtonColor: '#d33',
          cancelButtonText: 'Cancel'
        }).then((result) => {
          if (result.isConfirmed) {
            $.ajax({
              url: apiUrl + '/user-management/deleteUser',
              method: 'POST',
              contentType: 'application/json',
              data: JSON.stringify({ user_no: userNo }),
              success: function (response) {
                if (response.success) {
                  Swal.fire({
                    icon: 'success',
                    title: 'Deleted!',
                    text: response.message || 'User deleted successfully.'
                  });
                  userTable.ajax.reload(null, false);
                  inactiveUsersTable.ajax.reload(null, false);
                  return;
                }

                Swal.fire({
                  icon: 'error',
                  title: 'Failed',
                  text: response.message || 'Failed to delete user.'
                });
              },
              error: function () {
                Swal.fire({
                  icon: 'error',
                  title: 'Error',
                  text: 'An error occurred while deleting the user.'
                });
              }
            });
          }
        });
      });

      $(document).on('click', '.activate-user-btn', function () {
        if (!isAdminUser) return;
        const userNo = $(this).data('id');

        Swal.fire({
          title: 'Activate user?',
          text: 'Are you sure you want to activate this user?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: 'Yes, activate',
          confirmButtonColor: '#22c55e',
          cancelButtonText: 'Cancel'
        }).then((result) => {
          if (result.isConfirmed) {
            $.ajax({
              url: apiUrl + '/user-management/activateUser',
              method: 'POST',
              contentType: 'application/json',
              data: JSON.stringify({ user_no: userNo }),
              success: function (response) {
                if (response.success) {
                  Swal.fire({
                    icon: 'success',
                    title: 'Activated!',
                    text: response.message || 'User activated successfully.'
                  });
                  if (inactiveUsersTable) inactiveUsersTable.ajax.reload(null, false);
                  userTable.ajax.reload(null, false);
                  return;
                }

                Swal.fire({
                  icon: 'error',
                  title: 'Failed',
                  text: response.message || 'Failed to activate user.'
                });
              },
              error: function () {
                Swal.fire({
                  icon: 'error',
                  title: 'Error',
                  text: 'An error occurred while activating the user.'
                });
              }
            });
          }
        });
      });
    });
  </script>
</body>
</html>