<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" crossorigin="anonymous"></script>
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="icon" type="image/png" href="/Images/ndh-it.png">

  <style>
    /* Hide DataTables' default processing overlay; we use skeleton loaders instead. */
    .dt-processing {
      display: none !important;
    }
  </style>
</head>
<body class="bg-gray-100">
  <!-- Page Skeleton Loader (initial page/data load) - main content only (keeps sidebar visible) -->
  <div id="pageSkeleton" class="fixed inset-0 z-[60] hidden pointer-events-none">
    <div id="pageSkeletonContent" class="h-full bg-gray-100 overflow-auto">
      <main class="p-8" style="min-width: 0; max-width: 100%;">
      <div class="animate-pulse">
        <div class="h-8 w-40 bg-gray-200 rounded mb-6"></div>
        <div class="grid grid-cols-1 lg:grid-cols-2 2xl:grid-cols-3 gap-6">
          <section class="bg-white rounded-xl shadow p-5">
            <div class="flex items-center justify-between mb-4">
              <div class="h-5 w-56 bg-gray-200 rounded"></div>
              <div class="h-4 w-20 bg-gray-200 rounded"></div>
            </div>
            <div class="h-96 bg-gray-200/60 rounded"></div>
          </section>
          <section class="bg-white rounded-xl shadow p-5">
            <div class="flex items-center justify-between mb-4">
              <div class="h-5 w-44 bg-gray-200 rounded"></div>
              <div class="h-4 w-20 bg-gray-200 rounded"></div>
            </div>
            <div class="h-96 bg-gray-200/60 rounded"></div>
          </section>
          <section class="bg-white rounded-xl shadow p-5">
            <div class="flex items-center justify-between mb-4">
              <div class="h-5 w-64 bg-gray-200 rounded"></div>
              <div class="h-4 w-20 bg-gray-200 rounded"></div>
            </div>
            <div class="h-96 bg-gray-200/60 rounded"></div>
          </section>
        </div>

        <section class="bg-white rounded-xl shadow p-5 mt-8">
          <div class="flex items-center justify-between mb-4">
            <div class="h-5 w-40 bg-gray-200 rounded"></div>
            <div class="h-4 w-36 bg-gray-200 rounded"></div>
          </div>
          <div class="space-y-3">
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
          </div>
        </section>
      </div>
      </main>
    </div>
  </div>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'dashboard', baseUrl: baseUrl, accessLevel: accessLevel }) %>
    
    <main class="ml-72 flex-1 p-8">
      <h1 style="color: #0F828C;" class="text-3xl font-semibold">Dashboard</h1>

      <div class="mt-6 grid grid-cols-1 lg:grid-cols-2 2xl:grid-cols-3 gap-6">
        <section class="bg-white rounded-xl shadow p-5 flex flex-col">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700">Inventory Status (Computers)</h2>
            <span id="inventoryChartMeta" class="text-xs text-gray-500"></span>
          </div>
          <div class="h-96">
            <canvas id="inventoryChart"></canvas>
          </div>
        </section>

        <section class="bg-white rounded-xl shadow p-5 flex flex-col">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700">Peripherals by Type</h2>
            <span id="peripheralsChartMeta" class="text-xs text-gray-500"></span>
          </div>
          <div class="h-96">
            <canvas id="peripheralsChart"></canvas>
          </div>
        </section>

        <section class="bg-white rounded-xl shadow p-5 flex flex-col">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700">Consumables Stock by Classification</h2>
            <span id="consumablesChartMeta" class="text-xs text-gray-500"></span>
          </div>
          <div class="h-96">
            <canvas id="consumablesChart"></canvas>
          </div>
        </section>
      </div>

      <section id="dashboardSummaryCard" class="mt-8 bg-white rounded-xl shadow p-5 relative" aria-busy="true">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-semibold text-gray-700">Charts Summary</h2>
          <span class="text-xs text-gray-500">Auto-updates with charts</span>
        </div>
        <!-- Skeleton Loader (shown while table is being rebuilt) -->
        <div id="dashboardSummarySkeleton" class="absolute inset-0 z-10 bg-white/80 backdrop-blur-[1px] rounded-xl hidden pointer-events-none">
          <div class="p-5 animate-pulse">
            <div class="flex items-center justify-between mb-5">
              <div class="h-5 w-40 bg-gray-200 rounded"></div>
              <div class="h-9 w-36 bg-gray-200 rounded"></div>
            </div>
            <div class="space-y-3">
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
            </div>
          </div>
        </div>

        <div id="dashboardSummaryHost" class="w-full overflow-x-auto">
          <table id="dashboardSummaryTable" class="display nowrap" style="width:100%">
            <thead style="background-color: #0F828C;">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Category</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Label</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Value</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <script>
    let inventoryChart = null;
    let peripheralsChart = null;
    let consumablesChart = null;
    let dashboardSummaryDt = null;

    const pageSkeleton = document.getElementById('pageSkeleton');
    let initialLoadComplete = false;

    const summarySkeleton = document.getElementById('dashboardSummarySkeleton');
    const summaryHost = document.getElementById('dashboardSummaryHost');
    const summaryCard = document.getElementById('dashboardSummaryCard');
    let summarySkeletonShownAt = 0;
    const SUMMARY_SKELETON_MIN_MS = 250;
    function showSummarySkeleton() {
      if (summarySkeleton) summarySkeleton.classList.remove('hidden');
      if (summaryCard) summaryCard.setAttribute('aria-busy', 'true');
      summarySkeletonShownAt = Date.now();
    }
    function hideSummarySkeleton() {
      const elapsed = Date.now() - summarySkeletonShownAt;
      const delay = Math.max(0, SUMMARY_SKELETON_MIN_MS - elapsed);
      setTimeout(() => {
        if (summarySkeleton) summarySkeleton.classList.add('hidden');
        if (summaryCard) summaryCard.setAttribute('aria-busy', 'false');
      }, delay);
    }
    function syncPageSkeletonOffset() {
      const mainEl = document.querySelector('main');
      const contentEl = document.getElementById('pageSkeletonContent');
      if (!mainEl || !contentEl) return;
      const ml = window.getComputedStyle(mainEl).marginLeft;
      contentEl.style.marginLeft = ml;
    }

    function showPageSkeleton() {
      if (!pageSkeleton) return;
      syncPageSkeletonOffset();
      pageSkeleton.classList.remove('hidden');
      document.body.setAttribute('aria-busy', 'true');
    }
    function hidePageSkeleton() {
      if (!pageSkeleton) return;
      pageSkeleton.classList.add('hidden');
      document.body.setAttribute('aria-busy', 'false');
    }

    window.addEventListener('resize', syncPageSkeletonOffset);

    let socketRefreshTimer;

    const meta = {
      inventory: document.getElementById("inventoryChartMeta"),
      peripherals: document.getElementById("peripheralsChartMeta"),
      consumables: document.getElementById("consumablesChartMeta")
    };

    async function fetchData(url) {
      const response = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          draw: 1,
          start: 0,
          length: 100000,
          search: { value: "" },
          order: [{ column: 0, dir: "asc" }]
        })
      });

      if (!response.ok) {
        throw new Error(`Failed to fetch ${url}`);
      }

      const payload = await response.json();
      return Array.isArray(payload.data) ? payload.data : [];
    }

    function countBy(items, keyGetter) {
      const counts = {};
      items.forEach((item) => {
        const key = (keyGetter(item) || "Unknown").toString().trim() || "Unknown";
        counts[key] = (counts[key] || 0) + 1;
      });
      return counts;
    }

    function sumBy(items, keyGetter, valueGetter) {
      const sums = {};
      items.forEach((item) => {
        const key = (keyGetter(item) || "Unknown").toString().trim() || "Unknown";
        sums[key] = (sums[key] || 0) + (Number(valueGetter(item)) || 0);
      });
      return sums;
    }

    function drawChart(existingChart, canvasId, type, labels, values, colorSet, datasetLabel) {
      const chartCanvas = document.getElementById(canvasId);
      if (!chartCanvas) return existingChart;

      if (existingChart) {
        existingChart.destroy();
      }

      return new Chart(chartCanvas, {
        type,
        data: {
          labels,
          datasets: [{
            label: datasetLabel,
            data: values,
            backgroundColor: colorSet,
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "bottom" }
          }
        }
      });
    }

    function setMeta(el, text) {
      if (!el) return;
      el.textContent = text || "";
    }

    function formatNumber(value) {
      const n = Number(value);
      if (!Number.isFinite(n)) return "0";
      return new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 }).format(n);
    }

    function buildSummaryRows(inventoryStatusCount, peripheralTypeCount, consumableStockByClass) {
      const rows = [];

      Object.entries(inventoryStatusCount || {}).forEach(([label, value]) => {
        rows.push({ category: "Computers - Status", label, value: Number(value) || 0 });
      });
      Object.entries(peripheralTypeCount || {}).forEach(([label, value]) => {
        rows.push({ category: "Peripherals - Type", label, value: Number(value) || 0 });
      });
      Object.entries(consumableStockByClass || {}).forEach(([label, value]) => {
        rows.push({ category: "Consumables - Classification", label, value: Number(value) || 0 });
      });

      return rows;
    }

    function renderSummaryTable(rows) {
      const tableEl = document.getElementById("dashboardSummaryTable");
      if (!tableEl) return;

      try {
        if (dashboardSummaryDt) {
          dashboardSummaryDt.destroy();
          dashboardSummaryDt = null;
        }
      } catch (e) {
        dashboardSummaryDt = null;
      }

      const tbody = tableEl.querySelector("tbody");
      if (!tbody) return;
      tbody.innerHTML = "";

      (rows || []).forEach((row) => {
        const tr = document.createElement("tr");

        const tdCategory = document.createElement("td");
        tdCategory.className = "px-4 py-3 whitespace-nowrap";
        tdCategory.textContent = row.category || "";

        const tdLabel = document.createElement("td");
        tdLabel.className = "px-4 py-3 whitespace-nowrap";
        tdLabel.textContent = row.label || "";

        const tdValue = document.createElement("td");
        tdValue.className = "px-4 py-3 whitespace-nowrap";
        tdValue.textContent = formatNumber(row.value);

        tr.appendChild(tdCategory);
        tr.appendChild(tdLabel);
        tr.appendChild(tdValue);
        tbody.appendChild(tr);
      });

      dashboardSummaryDt = new DataTable("#dashboardSummaryTable", {
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No data available in table',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
      });
    }

    async function loadDashboardCharts() {
      try {
        if (!initialLoadComplete) {
          showPageSkeleton();
        }

        showSummarySkeleton();

        setMeta(meta.inventory, "Loading...");
        setMeta(meta.peripherals, "Loading...");
        setMeta(meta.consumables, "Loading...");

        const [computers, peripherals, consumables] = await Promise.all([
          fetchData("/computers/computerDataTable"),
          fetchData("/peripherals/peripheralDataTable"),
          fetchData("/consumable/showConsumables")
        ]);

        const inventoryStatusCount = countBy(computers, (item) => item.pc_status || "Unknown");
        const peripheralTypeCount = countBy(peripherals, (item) => item.kind_of_peripheral || "Unknown");
        const consumableStockByClass = sumBy(consumables, (item) => item.item_classification || "Unknown", (item) => item.current_stock || 0);

        renderSummaryTable(buildSummaryRows(inventoryStatusCount, peripheralTypeCount, consumableStockByClass));
        hideSummarySkeleton();

        inventoryChart = drawChart(
          inventoryChart,
          "inventoryChart",
          "doughnut",
          Object.keys(inventoryStatusCount),
          Object.values(inventoryStatusCount),
          ["#0F828C", "#22c55e", "#f59e0b", "#ef4444", "#6b7280", "#14b8a6"],
          "Inventory Status"
        );

        peripheralsChart = drawChart(
          peripheralsChart,
          "peripheralsChart",
          "bar",
          Object.keys(peripheralTypeCount),
          Object.values(peripheralTypeCount),
          ["#0ea5e9", "#2563eb", "#8b5cf6", "#06b6d4", "#6366f1", "#14b8a6"],
          "Peripheral Count"
        );

        consumablesChart = drawChart(
          consumablesChart,
          "consumablesChart",
          "bar",
          Object.keys(consumableStockByClass),
          Object.values(consumableStockByClass),
          ["#10b981", "#84cc16", "#22c55e", "#16a34a", "#65a30d", "#4d7c0f"],
          "Current Stock"
        );

        setMeta(meta.inventory, `${computers.length} items`);
        setMeta(meta.peripherals, `${peripherals.length} items`);
        setMeta(meta.consumables, `${consumables.length} items`);
      } catch (error) {
        console.error(error);
        setMeta(meta.inventory, "Load failed");
        setMeta(meta.peripherals, "Load failed");
        setMeta(meta.consumables, "Load failed");

        if (window.Swal) {
          Swal.fire({
            icon: "error",
            title: "Load failed",
            text: "Unable to load dashboard charts. Please try again."
          });
        }

        hideSummarySkeleton();
      }

      if (!initialLoadComplete) {
        hidePageSkeleton();
        initialLoadComplete = true;
      }
    }

    function scheduleSocketRefresh() {
      clearTimeout(socketRefreshTimer);
      socketRefreshTimer = setTimeout(() => {
        loadDashboardCharts();
      }, 600);
    }

    function setupSocket() {
      if (typeof io !== "function") return;

      const socket = io();

      socket.on("connect", () => {
        console.log("Dashboard socket connected");
      });

      socket.on("reports:refresh", () => {
        scheduleSocketRefresh();
      });

      socket.on("disconnect", () => {
        console.log("Dashboard socket disconnected");
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      setupSocket();
      showSummarySkeleton();
      loadDashboardCharts();
    });
  </script>
</body>
</html>
