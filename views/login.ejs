<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - NDH IT Inventory</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/fontawesome/css/all.min.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tsparticles@2.10.1/tsparticles.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <link rel="shortcut icon" href="favicon.icon" type="image/x-icon">

  <style>
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
      display: none;
    }

    input[type="password"]::-webkit-credentials-auto-fill-button,
    input[type="password"]::-webkit-password-toggle-button {
      display: none !important;
    }
  </style>
</head>

<body
  class="bg-gradient-to-br from-[#0F828C] via-[#0d6d76] to-[#0a565c] min-h-screen flex items-center justify-center font-sans relative overflow-hidden">

  <div id="tsparticles" class="fixed top-0 left-0 w-full h-full -z-10"></div>

  <!-- Animated Background Elements -->
  <div class="absolute top-0 left-0 w-full h-full -z-10 overflow-hidden">
    <div class="absolute top-20 left-10 w-72 h-72 bg-teal-400/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-cyan-400/10 rounded-full blur-3xl animate-pulse delay-1000">
    </div>
  </div>

  <!-- Login Container -->
  <div
    class="bg-white/95 backdrop-blur-lg shadow-2xl rounded-2xl flex flex-col lg:flex-row justify-center items-center gap-8 lg:gap-12 w-full max-w-5xl p-8 lg:p-12 mx-auto relative z-10 border border-white/20 transition-all duration-300 hover:shadow-3xl">

    <!-- Left Section (Logos + Image) -->
    <div class="flex flex-col items-center justify-center w-full lg:w-auto animate-fade-in">
      <div class="flex flex-col items-center space-y-4 mb-8">
        <!-- Logo Header -->
        <div class="flex justify-center items-center space-x-4 px-4 mb-2">
          <img src="/images/qc-log.png" alt="Left Logo"
            class="w-12 h-12 md:w-20 md:h-20 object-contain transition-transform duration-300 hover:scale-110" />
          <h1 class="text-xl md:text-2xl font-bold text-[#0F828C] text-center whitespace-nowrap tracking-wide">
            Novaliches District Hospital
          </h1>
          <img src="/images/ndh.jpg" alt="Right Logo"
            class="w-10 h-10 md:w-20 md:h-20 object-contain transition-transform duration-300 hover:scale-110" />
        </div>

        <!-- Decorative Divider -->
        <div class="w-32 h-1 bg-gradient-to-r from-[#0F828C] to-teal-400 rounded-full"></div>
      </div>

      <!-- Main Image -->
      <div class="relative group mt-4">
        <div
          class="absolute -inset-6 bg-gradient-to-r from-[#0F828C] to-teal-400 rounded-full blur-2xl opacity-30 group-hover:opacity-50 transition duration-300">
        </div>
        <img src="/images/ndh-it.png" alt="Hospital Logo"
          class="relative w-48 h-48 md:w-60 md:h-60 object-contain transition-transform duration-300 group-hover:scale-105" />
      </div>
    </div>

    <!-- Vertical Divider (Desktop Only) -->
    <div class="hidden lg:block w-px h-80 bg-gradient-to-b from-transparent via-[#0F828C] to-transparent"></div>

    <!-- Right Section (Login Form UI only) -->
    <div class="w-full lg:w-1/2 max-w-md flex flex-col">
      <div class="mb-2 text-center">
        <h2 class="text-3xl font-bold text-gray-800 mb-2 flex items-center justify-center gap-3">
            <i class="fas fa-boxes-stacked text-[#0F828C]"></i>
            IT Login
        </h2>
        <p class="text-gray-600 text-sm">
          Sign in your inventory account 
        </p>
      </div>

      <form id="loginForm" class="space-y-5 mt-6" autocomplete="on">
        <!-- Username Input -->
        <div class="group">
          <label for="username"
            class="block mb-2 text-sm font-semibold text-gray-700 transition-colors group-focus-within:text-[#0F828C]">
            Username
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <input type="text" id="username" name="username" required
              class="w-full pl-10 pr-4 py-3 rounded-lg border-2 border-gray-300 text-base transition-all duration-200 focus:outline-none focus:border-[#0F828C] focus:ring-4 focus:ring-[#0F828C]/10 hover:border-gray-400"
              placeholder="Enter your username" />
          </div>
        </div>

        <!-- Password Input -->
        <div class="group">
          <label for="password"
            class="block mb-2 text-sm font-semibold text-gray-700 transition-colors group-focus-within:text-[#0F828C]">
            Password
          </label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                </path>
              </svg>
            </div>
            <input type="password" id="password" name="password" required
              class="w-full pl-10 pr-12 py-3 rounded-lg border-2 border-gray-300 text-base transition-all duration-200 focus:outline-none focus:border-[#0F828C] focus:ring-4 focus:ring-[#0F828C]/10 hover:border-gray-400"
              placeholder="Enter your password" />

            <button type="button" id="togglePassword"
              class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-[#0F828C] transition-colors duration-200"
              aria-label="Toggle password visibility">
              <svg id="eyeIcon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z">
                </path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Login Button (UI only) -->
        <div class="pt-2">
          <button type="submit"
            class="w-full bg-gradient-to-r from-[#0F828C] to-teal-600 text-white font-semibold text-base py-3.5 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98] hover:from-[#0d6d76] hover:to-[#0d8995] focus:outline-none focus:ring-4 focus:ring-[#0F828C]/30 group">
            <span class="flex items-center justify-center space-x-2">
              <span>LOGIN</span>
              <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none"
                stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Scripts (UI-only) -->
  <script>
    $(document).ready(function () {
      // Initialize tsparticles (pure UI)
      tsParticles.load("tsparticles", {
        background: { color: { value: "#0F828C" } },
        fpsLimit: 60,
        interactivity: {
          events: {
            onHover: { enable: true, mode: ["attract", "slow"] },
            resize: true
          },
          modes: {
            attract: { distance: 200, duration: 0.4 },
            slow: { factor: 2, radius: 100 }
          }
        },
        particles: {
          color: { value: "#00ffff" },
          links: { enable: true, color: "#00ffff", distance: 150, opacity: 0.5, width: 1 },
          collisions: { enable: false },
          move: { enable: true, speed: 1.2, direction: "none", random: true, straight: false, outModes: "out" },
          number: { density: { enable: true, area: 800 }, value: 80 },
          opacity: { value: 0.5 },
          shape: { type: "triangle" },
          size: { value: { min: 1, max: 4 } }
        },
        detectRetina: true
      });

      // Handle login form submission
      $('#loginForm').on('submit', function (e) {
        e.preventDefault();
        
        const username = $('#username').val().trim();
        const password = $('#password').val();
        const submitButton = $(this).find('button[type="submit"]');
        
        // Validate inputs
        if (!username || !password) {
          Swal.fire({
            icon: 'warning',
            title: 'Incomplete Fields',
            text: 'Please enter username and password',
            confirmButtonColor: '#0F828C'
          });
          return;
        }
        
        // Disable submit button
        submitButton.prop('disabled', true).html('<span>Logging in...</span>');
        
        // Send login request
        $.ajax({
          url: '/login/submit',
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify({ username, password }),
          success: function(response) {
            if (response.success) {
              Swal.fire({
                icon: 'success',
                title: 'Login Successful!',
                text: response.message,
                confirmButtonColor: '#0F828C',
                timer: 1500,
                showConfirmButton: false
              }).then(() => {
                window.location.href = response.redirect || '/dashboard';
              });
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Login Failed',
                text: response.message,
                confirmButtonColor: '#0F828C'
              });
              submitButton.prop('disabled', false).html('<span class="flex items-center justify-center space-x-2"><span>LOGIN</span><svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg></span>');
            }
          },
          error: function(xhr) {
            const response = xhr.responseJSON || {};
            Swal.fire({
              icon: 'error',
              title: 'Login Failed',
              text: response.message || 'Login failed. Please try again.',
              confirmButtonColor: '#0F828C'
            });
            submitButton.prop('disabled', false).html('<span class="flex items-center justify-center space-x-2"><span>LOGIN</span><svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg></span>');
          }
        });
      });

      // Password visibility toggle (UI-only)
      $('#togglePassword').on('click', function () {
        const passwordInput = $('#password');
        const eyeIcon = $('#eyeIcon');
        const type = passwordInput.attr('type') === 'password' ? 'text' : 'password';
        passwordInput.attr('type', type);

        if (type === 'text') {
          eyeIcon.html('<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>');
        } else {
          eyeIcon.html('<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>');
        }
      });
    }); 
  </script>

</body>

</html>