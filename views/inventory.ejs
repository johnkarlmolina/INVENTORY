    </div>
  </div>

  <div id="computerModal" class="fixed inset-0 z-50 hidden">
    <div id="computerModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-7xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Computer Inventory Form</h2>
          <button id="closeComputerModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="computerForm" class="px-6 py-6">
          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label for="brand" class="block text-sm font-medium text-gray-700 mb-2">Brand</label>
                <input id="brand" name="brand" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="model" class="block text-sm font-medium text-gray-700 mb-2">Model</label>
                <input id="model" name="model" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="computer_file" class="block text-sm font-medium text-gray-700 mb-2">Upload Picture/File</label>
                <input id="computer_file" name="computer_file" type="file"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="procie" class="block text-sm font-medium text-gray-700 mb-2">Processor</label>
                <input id="procie" name="procie" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="ram" class="block text-sm font-medium text-gray-700 mb-2">RAM</label>
                <input id="ram" name="ram" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
              <div>
                <label for="pc_no" class="block text-sm font-medium text-gray-700 mb-2">PC Number</label>
                <input id="pc_no" name="pc_no" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="property_tag" class="block text-sm font-medium text-gray-700 mb-2">Property Tag</label>
                <input id="property_tag" name="property_tag" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label for="serial_number" class="block text-sm font-medium text-gray-700 mb-2">Serial Number</label>
                <input id="serial_number" name="serial_number" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="rounded-2xl border border-gray-200 p-4 grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="pc_status" class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                <select id="pc_status" name="pc_status"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="active" selected>Active</option>
                  <option value="inactive">Inactive</option>
                  <option value="inrepair">In Repair</option>
                  <option value="condemned">Condemned</option>
                </select>
              </div>
              <div>
                <label for="pc_location" class="block text-sm font-medium text-gray-700 mb-2">PC Location</label>
                <select id="pc_location" name="pc_location"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                <option value="Floor" selected>Floor</option>
                  <option value="1st Floor">1st Floor</option>
                  <option value="2nd Floor">2nd Floor</option>
                  <option value="3rd Floor">3rd Floor</option>
                  <option value="4th Floor">4th Floor</option>
                </select>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="pc_user" class="block text-sm font-medium text-gray-700 mb-2">PC User</label>
                <input id="pc_user" name="pc_user" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="user_dept" class="block text-sm font-medium text-gray-700 mb-2">Department</label>
                <select id="user_dept" name="user_dept"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="">Select department...</option>
                  <option value="IT Department">IT Department</option>
                  <option value="Accounting">Accounting</option>
                  <option value="HR">HR</option>
                  <option value="Admin">Admin</option>
                  <option value="Operations">Operations</option>
                  <option value="Engineering">Engineering</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="os_version" class="block text-sm font-medium text-gray-700 mb-2">OS Version</label>
                <input id="os_version" name="os_version" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="os_license" class="block text-sm font-medium text-gray-700 mb-2">OS License</label>
                <input id="os_license" name="os_license" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <section class="mb-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label for="date_of_purchase" class="block text-sm font-medium text-gray-700 mb-2">Date of Purchase</label>
                <input id="date_of_purchase" name="date_of_purchase" type="date"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="date_of_entry" class="block text-sm font-medium text-gray-700 mb-2">Date of Entry</label>
                <input id="date_of_entry" name="date_of_entry" type="date"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="office_license" class="block text-sm font-medium text-gray-700 mb-2">Office License</label>
                <input id="office_license" name="office_license" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <div class="flex items-center gap-4">
            <button type="submit" id="submitComputerForm"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-plus text-lg"></i>
              <span class="font-semibold">Add Computer</span>
