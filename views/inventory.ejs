<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inventory - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- DataTables (Default) -->
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="icon" type="image/png" href="/Images/ndh-it.png">

  <style>
    /* Hide DataTables' default processing overlay; we use a skeleton loader instead. */
    .dt-processing {
      display: none !important;
    }
  </style>
</head>

<body class="bg-gray-100 overflow-x-hidden">
  <!-- Page Skeleton Loader (initial page/data load) - main content only (keeps sidebar visible) -->
  <div id="pageSkeleton" class="fixed inset-0 z-[60] hidden pointer-events-none">
    <div id="pageSkeletonContent" class="h-full bg-gray-100 overflow-auto">
      <main class="p-8" style="min-width: 0; max-width: 100%;">
      <div class="animate-pulse">
        <div class="mb-6">
          <div class="h-10 w-80 bg-gray-200 rounded mb-3"></div>
          <div class="h-5 w-64 bg-gray-200 rounded"></div>
        </div>

        <div class="flex justify-end mb-4 gap-4">
          <div class="h-12 w-40 bg-gray-200 rounded-xl"></div>
          <div class="h-12 w-36 bg-gray-200 rounded-xl"></div>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto">
          <div class="flex items-center justify-between mb-6">
            <div class="h-6 w-64 bg-gray-200 rounded"></div>
            <div class="h-9 w-40 bg-gray-200 rounded"></div>
          </div>
          <div class="space-y-3">
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
          </div>
        </div>
      </div>
    </main>
  </div>
  </div>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'inventory', baseUrl: baseUrl, accessLevel: accessLevel }) %>

      <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden"
        style="min-width: 0; max-width: 100%;">
        <div class="mb-6">
          <h1 style="color: #0F828C;" class="text-4xl font-bold">Computer Inventory</h1>
          <p style="color: #777777;" class="text-2x1">Computer inventory overview</p>
        </div>

        <!-- Button Container -->
        <div class="flex justify-end mb-4">
          <% if (isAdmin) { %>
            <button id="openComputerModal"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-plus text-lg"></i>
              <span class="font-semibold">Add Computer</span>
            </button>

            <button id="openInactiveModal" class="ml-4 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-600 text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-red-600 focus:ring-opacity-50">
              <i class="fas fa-ban text-lg"></i>
              <span class="font-semibold">Inactive</span>
            </button>
          <% } %>
        </div>
          
        <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto relative" id="inventoryTableCard" aria-busy="true">
          <!-- Skeleton Loader (shown while DataTables is fetching) -->
          <div id="inventorySkeleton" class="absolute inset-0 z-10 bg-white/80 backdrop-blur-[1px] rounded-lg">
            <div class="p-6 animate-pulse">
              <div class="flex items-center justify-between mb-6">
                <div class="h-6 w-64 bg-gray-200 rounded"></div>
                <div class="h-9 w-40 bg-gray-200 rounded"></div>
              </div>

              <div class="space-y-3">
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
                <div class="h-10 w-full bg-gray-200 rounded"></div>
              </div>
            </div>
          </div>

          <div class="w-full overflow-x-auto opacity-0" id="inventoryTableHost">
            <table id="dashboardTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">PC Number</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Brand</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Model</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Serial</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Property Tag</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">OS Version</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Processor</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">RAM</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">OS License</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">User</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Department</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Date of Purchase</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Date of Entry</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Office License</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">PC Status</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">PC Location</th>
                  <% if (isAdmin) { %>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                  <% } %>
