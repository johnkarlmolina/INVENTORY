  <!-- Inactive Computers Modal -->
  <div id="inactiveModal" class="fixed inset-0 z-50 hidden">
    <div id="inactiveModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-5xl rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">Inactive Computers</h2>
          <button id="closeInactiveModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <div class="px-6 py-6">
          <div class="overflow-x-auto">
            <table id="inactiveTable" class="display nowrap" style="width:100%">
              <thead style="background-color: #0F828C;">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">PC Number</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Brand</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Model</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">User</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  
</body>

</html>


<script>

 $(document).ready(function() {
   const apiUrl = "<%= baseUrl %>";
  const isAdminUser = JSON.parse('<%- JSON.stringify(!!isAdmin) %>');

    // Full-page skeleton (initial load only)
    const $pageSkeleton = $('#pageSkeleton');
    let initialLoadComplete = false;
    function syncPageSkeletonOffset() {
      const mainEl = document.querySelector('main');
      const contentEl = document.getElementById('pageSkeletonContent');
      if (!mainEl || !contentEl) return;
      const ml = window.getComputedStyle(mainEl).marginLeft;
      contentEl.style.marginLeft = ml;
    }

    function showPageSkeleton() {
      syncPageSkeletonOffset();
      $pageSkeleton.removeClass('hidden');
      $('body').attr('aria-busy', 'true');
    }
    function hidePageSkeleton() {
      $pageSkeleton.addClass('hidden');
      $('body').attr('aria-busy', 'false');
    }

    // Keep skeleton aligned if sidebar width/margins change.
    window.addEventListener('resize', syncPageSkeletonOffset);

    // Skeleton loader helpers for the main inventory table
    const $inventorySkeleton = $('#inventorySkeleton');
    const $inventoryTableHost = $('#inventoryTableHost');
    const $inventoryTableCard = $('#inventoryTableCard');
    function showInventorySkeleton() {
      $inventorySkeleton.removeClass('hidden');
      $inventoryTableHost.addClass('opacity-0');
      $inventoryTableCard.attr('aria-busy', 'true');
    }
    function hideInventorySkeleton() {
      $inventorySkeleton.addClass('hidden');
      $inventoryTableHost.removeClass('opacity-0');
      $inventoryTableCard.attr('aria-busy', 'false');
    }

    // Start in loading state until the first DataTables response arrives.
    showInventorySkeleton();
    showPageSkeleton();

    const $computerModal = $('#computerModal');
    const $computerForm = $('#computerForm');
    let isEditMode = false;
    let editComputerId = null;

    // Function to format date to YYYY-MM-DD for HTML date input
    function formatDateForInput(dateString) {
      if (!dateString) return '';
      
      // If already in YYYY-MM-DD format, return as is
      if (/^\d{4}-\d{2}-\d{2}$/.test(dateString)) {
        return dateString;
      }
      
      // Try to parse and format the date
      const date = new Date(dateString);
      if (isNaN(date.getTime())) return ''; // Invalid date
      
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      
      return `${year}-${month}-${day}`;
    }

    function openComputerModal(editMode = false) {
      isEditMode = editMode;
      if (editMode) {
        $('#computerModal h2').text('Edit Computer');
        $('#computerForm button[type="submit"] span').text('Update Computer');
        $('#computerForm button[type="submit"] i').removeClass('fa-plus').addClass('fa-save');
      } else {
        $('#computerModal h2').text('Computer Inventory Form');
        $('#computerForm button[type="submit"] span').text('Add Computer');
        $('#computerForm button[type="submit"] i').removeClass('fa-save').addClass('fa-plus');
        editComputerId = null;
        
        // Clear all form fields when opening in Add mode
        $computerForm[0].reset();
        $('#pc_status').val('active');
      }
      $computerModal.removeClass('hidden');
      $('body').addClass('overflow-hidden');
    }

    function closeComputerModal() {
      $computerModal.addClass('hidden');
      $('body').removeClass('overflow-hidden');
      isEditMode = false;
      editComputerId = null;
      
      // Clear form when closing to prevent data leakage to next open
      $computerForm[0].reset();
      $('#pc_status').val('active');
    }

    const baseColumns = [
      { data: 'pc_no' },
      { data: 'brand' },
      { data: 'model' },
      { data: 'serial_number' },
      { data: 'property_tag' },
      { data: 'os_version' },
      { data: 'procie' },
      { data: 'ram' },
      { data: 'os_license' },
      { data: 'pc_user' },
      { data: 'user_dept' },
      { data: 'date_of_purchase' },
      { data: 'date_of_entry' },
      { data: 'office_license' },
      { data: 'pc_status' },
      { data: 'pc_location' }
    ];

    if (isAdminUser) {
      baseColumns.push({
        data: 'computer_id',
        orderable: false,
        searchable: false,
        render: function (id) {
          return `
            <div class="flex gap-2">
              <button class="editBtn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Edit">
                <i class="fas fa-edit"></i> Edit
              </button>
              <button class="fileBtn bg-white border-2 border-green-500 text-green-500 hover:bg-green-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Upload File">
                <i class="fas fa-file-upload"></i> File
              </button>
              <button class="deleteBtn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Delete">
                <i class="fas fa-trash"></i> Delete
              </button>
            </div>
          `;
        }
      });
    }

    const baseColumnDefs = [
      { width: '60px', targets: 0 },  // PC Number
      { width: '80px', targets: 1 },  // Brand
      { width: '80px', targets: 2 },  // Model
      { width: '120px', targets: 3 }, // Serial
      { width: '100px', targets: 4 }, // Property Tag
      { width: '100px', targets: 5 }, // OS Version
      { width: '120px', targets: 6 }, // Processor
      { width: '60px', targets: 7 },  // RAM
      { width: '100px', targets: 8 }, // OS License
      { width: '120px', targets: 9 }, // User
      { width: '150px', targets: 10 }, // Department
      { width: '110px', targets: 11 }, // Date of Purchase
      { width: '110px', targets: 12 }, // Date of Entry
      { width: '180px', targets: 13 }, // Office License
      { width: '100px', targets: 14 }, // PC Status
      { width: '100px', targets: 15 }  // PC Location
    ];
    if (isAdminUser) {
      baseColumnDefs.push({ width: '100px', targets: 16, className: 'text-center' });
    }

    const table = new DataTable('#dashboardTable', {
      processing: true,
       serverSide: true,
      ajax: {
        url: apiUrl+'/computers/computerDataTable',
        type: 'POST',
        dataType: 'json'
      },
      columns: baseColumns,
      pageLength: 10,
      ordering: true,
      searching: true,
      info: true,
      scrollX: true,
      scrollCollapse: true,
      responsive: false,
      autoWidth: false,
      columnDefs: baseColumnDefs,
      language: {
        search: 'Search:',
        lengthMenu: 'Show _MENU_ entries',
        info: 'Showing _START_ to _END_ of _TOTAL_ entries',
        infoEmpty: 'Showing 0 to 0 of 0 entries',
        infoFiltered: '(filtered from _MAX_ total entries)',
        zeroRecords: 'No matching records found',
        emptyTable: 'No data available in table',
        paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
      }
    });

    // Toggle skeleton during server-side DataTables AJAX requests.
    // DataTables v2 instantiated via `new DataTable()` may not emit the jQuery `*.dt` events,
    // so we bind to the DataTables instance events and keep a jQuery fallback.
    if (table && typeof table.on === 'function') {
      table.on('preXhr', function () {
        if (!initialLoadComplete) {
          showPageSkeleton();
        } else {
          showInventorySkeleton();
        }
      });
      table.on('xhr', function () {
        hideInventorySkeleton();
        hidePageSkeleton();
        initialLoadComplete = true;
      });
      table.on('error', function () {
        // If the request fails, stop showing the skeleton to avoid a stuck state.
        hideInventorySkeleton();
        hidePageSkeleton();
        initialLoadComplete = true;
      });
    }

    $('#dashboardTable')
      .on('preXhr.dt', function () {
        if (!initialLoadComplete) {
          showPageSkeleton();
        } else {
          showInventorySkeleton();
        }
      })
      .on('xhr.dt', function () {
        hideInventorySkeleton();
        hidePageSkeleton();
        initialLoadComplete = true;
      })
      .on('error.dt', function () {
        // If the request fails, stop showing the skeleton to avoid a stuck state.
        hideInventorySkeleton();
        hidePageSkeleton();
        initialLoadComplete = true;
      });

    if (isAdminUser) {
      $('#openComputerModal').on('click', function() {
        // Force clear form before opening in Add mode
        $computerForm[0].reset();
        $('#pc_status').val('active');
        $('#pc_location').val('');
        $('#user_dept').val('');
        editComputerId = null;
        isEditMode = false;
        
        // Then open modal
        openComputerModal(false);
      });
    }
    
    $('#closeComputerModal, #computerModalBackdrop').on('click', closeComputerModal);

    // Inactive button handler (Admin only)
    const $inactiveModal = $('#inactiveModal');
    let inactiveTable = null;
    if (isAdminUser) {
      inactiveTable = new DataTable('#inactiveTable', {
      processing: true,
      serverSide: true,
      ajax: {
        url: apiUrl + '/computers/inactiveComputerDataTable',
        type: 'POST',
        dataType: 'json'
      },
      columns: [
        { data: 'pc_no' },
        { data: 'brand' },
        { data: 'model' },
        { data: 'pc_user' },
        // Actions column (buttons) - only Active button
        {
          data: 'computer_id',
          orderable: false,
          searchable: false,
          render: function (id) {
            return `
              <div class="flex gap-2">
                <button class="activateBtn bg-green-500 border-2 border-green-500 text-white hover:bg-green-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Activate">
                  <i class="fas fa-check"></i> Activate
                </button>
              </div>
            `;
          }
        }
      ],
      pageLength: 10,
      ordering: true,
      searching: true,
      info: true,
      scrollX: true,
      scrollCollapse: true,
      responsive: false,
      autoWidth: false,
      columnDefs: [
        { width: '100px', targets: 0 },   // PC Number
        { width: '100px', targets: 1 },   // Brand
        { width: '100px', targets: 2 },   // Model
        { width: '150px', targets: 3 },   // User
        { width: '120px', targets: 4, className: 'text-center' }  // Actions
      ],
      language: {
        search: 'Search:',
        lengthMenu: 'Show _MENU_ entries',
        info: 'Showing _START_ to _END_ of _TOTAL_ entries',
        infoEmpty: 'Showing 0 to 0 of 0 entries',
        infoFiltered: '(filtered from _MAX_ total entries)',
        zeroRecords: 'No matching records found',
        emptyTable: 'No inactive computers',
        paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
      }
      });

      $('#openInactiveModal').on('click', function() {
        $inactiveModal.removeClass('hidden');
        $('body').addClass('overflow-hidden');
        inactiveTable.ajax.reload(null, false);
      });
    }
    
    $('#closeInactiveModal, #inactiveModalBackdrop').on('click', function() {
      $inactiveModal.addClass('hidden');
      $('body').removeClass('overflow-hidden');
    });

    $(document).on('keydown', function (event) {
      if (event.key === 'Escape' && !$inactiveModal.hasClass('hidden')) {
        $inactiveModal.addClass('hidden');
        $('body').removeClass('overflow-hidden');
      }
    });

    // Activate button handler (Admin only)
    $('#inactiveTable').on('click', '.activateBtn', function () {
      if (!isAdminUser) return;
      const id = $(this).data('id');
      
      Swal.fire({
        title: 'Activate?',
        text: 'Are you sure you want to activate this computer?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, activate',
        confirmButtonColor: '#22c55e',
        cancelButtonColor: '#6c757d',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: apiUrl + '/computers/activateComputer',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ computer_id: id }),
            success: function(response) {
              if (response.success) {
                Swal.fire({
                  icon: 'success',
                  title: 'Activated!',
                  text: 'Computer has been activated.',
                  confirmButtonColor: '#22c55e'
                });
                inactiveTable.ajax.reload(null, false);
              } else {
                Swal.fire({
                  icon: 'error',
                  title: 'Failed',
                  text: response.message || 'Failed to activate computer.'
                });
              }
            },
            error: function() {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while activating the computer.'
              });
            }
          });
        }
      });
    });

    $(document).on('keydown', function (event) {
      if (event.key === 'Escape' && !$computerModal.hasClass('hidden')) {
        closeComputerModal();
      }
    });

    $('#clearComputerForm').on('click', function () {
      $computerForm.trigger('reset');
      $('#pc_status').val('active');
    });

    // Edit button handler (Admin only)
    $('#dashboardTable').on('click', '.editBtn', function () {
      if (!isAdminUser) return;
      const id = $(this).data('id');
      editComputerId = id;
      
      // Get row data from DataTable
      const rowData = table.row($(this).parents('tr')).data();
      
      console.log('Row data for edit:', rowData); // Debug log
      
      // Populate form fields
      $('#brand').val(rowData.brand || '');
      $('#model').val(rowData.model || '');
      $('#procie').val(rowData.procie || '');
      $('#ram').val(rowData.ram || '');
      $('#pc_no').val(rowData.pc_no || '');
      $('#property_tag').val(rowData.property_tag || '');
      $('#serial_number').val(rowData.serial_number || '');
      $('#pc_status').val((rowData.pc_status || 'active').toLowerCase());
      
      // Handle pc_location - add option if not exists
      if (rowData.pc_location && $('#pc_location option[value="' + rowData.pc_location + '"]').length === 0) {
        $('#pc_location').append(new Option(rowData.pc_location, rowData.pc_location));
      }
      $('#pc_location').val(rowData.pc_location || '');
      
      $('#pc_user').val(rowData.pc_user || '');
      
      // Handle user_dept - add option if not exists
      if (rowData.user_dept && $('#user_dept option[value="' + rowData.user_dept + '"]').length === 0) {
        $('#user_dept').append(new Option(rowData.user_dept, rowData.user_dept));
      }
      $('#user_dept').val(rowData.user_dept || '');
      $('#os_version').val(rowData.os_version || '');
      $('#os_license').val(rowData.os_license || '');
      $('#date_of_purchase').val(formatDateForInput(rowData.date_of_purchase));
      $('#date_of_entry').val(formatDateForInput(rowData.date_of_entry));
      $('#office_license').val(rowData.office_license || '');
      
      // Open modal in edit mode
      openComputerModal(true);
    });


    //  delete button with SweetAlert (Admin only)
    $('#dashboardTable').on('click', '.deleteBtn', function () {
      if (!isAdminUser) return;
      const id = $(this).data('id');

      Swal.fire({
        title: 'Delete?',
        text: 'Are you sure you want to delete this item?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, delete',
        confirmButtonColor: '#d33',
        cancelButtonColor: '#6c757d',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          $.ajax({
            url: apiUrl + '/computers/deleteComputer',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ computer_id: id }),
            success: function(response) {
              if (response.success) {
                Swal.fire({
                  icon: 'success',
                  title: 'Deleted!',
                  text: 'Computer has been deleted.',
                  confirmButtonColor: '#0F828C'
                });
                table.ajax.reload(null, false);
              } else {
                Swal.fire({
                  icon: 'error',
                  title: 'Failed',
                  text: response.message || 'Failed to delete computer.'
                });
              }
            },
            error: function() {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while deleting the computer.'
              });
            }
          });
        }
      });
    });

      // Ensure widths are correct after first layout/paint.
      setTimeout(function () {
        try {
          table.columns.adjust();
        } catch (e) {
          // ignore
        }
      }, 0);
      setTimeout(function () {
        try {
          table.columns.adjust();
        } catch (e) {
          // ignore
        }
      }, 350);


$(document).on('submit', '#computerForm', function (e) {
  if (!isAdminUser) return;
    e.preventDefault();

    const fileInput = document.getElementById('computer_file');
    const fileName = fileInput.files.length > 0 ? fileInput.files[0].name : null;

    // Convert form to object
    const formDataArray = $(this).serializeArray();
    let data = {};
    formDataArray.forEach(item => {
        data[item.name] = item.value.trim() === '' ? null : item.value.trim();
    });

    // Add filename manually
    data.picture_of_pc = fileName;
    
    // Determine if edit mode
    const isUpdate = isEditMode && editComputerId;
    const title = isUpdate ? 'Update Computer?' : 'Add Computer?';
    const text = isUpdate ? 'Are you sure you want to update this computer?' : 'Are you sure you want to add this computer?';
    const confirmText = isUpdate ? 'Yes, update it!' : 'Yes, add it!';
    const successTitle = isUpdate ? 'Computer Updated' : 'Computer Added';
    const apiEndpoint = isUpdate ? apiUrl + '/computers/updateComputer' : apiUrl + '/computers/addComputer';
    
    // Add ID if editing
    if (isUpdate) {
        data.computer_id = editComputerId;
    }

    // Show SweetAlert confirmation first
    Swal.fire({
        title: title,
        text: text,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#0F828C',
        cancelButtonColor: '#d33',
        confirmButtonText: confirmText,
        cancelButtonText: 'Cancel'
    }).then((result) => {
        if (result.isConfirmed) {
            // Send AJAX only after confirmation
            $.ajax({
                url: apiEndpoint,
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: successTitle,
                            text: response.message,
                            confirmButtonColor: '#0F828C'
                        });

                        closeComputerModal();
                        table.ajax.reload();
                        $('#computerForm')[0].reset();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: isUpdate ? 'Update Failed' : 'Insert Failed',
                            text: response.message,
                        });
                    }
                },
                error: function (xhr) {
                    console.error('AJAX error:', xhr.responseText);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong.'
                    });
                }
            });
        }
    });
});



    });
  </script>
