<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Peripherals - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- DataTables (Default) -->
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <!-- Tom Select -->
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

  <style>
    /* Hide DataTables' default processing overlay; we use a skeleton loader instead. */
    .dt-processing {
      display: none !important;
    }
  </style>
</head>

<body class="bg-gray-100 overflow-x-hidden">
  <!-- Page Skeleton Loader (initial page/data load) - main content only (keeps sidebar visible) -->
  <div id="pageSkeleton" class="fixed inset-0 z-[60] hidden pointer-events-none">
    <div id="pageSkeletonContent" class="h-full bg-gray-100 overflow-auto">
      <main class="p-8" style="min-width: 0; max-width: 100%;">
      <div class="animate-pulse">
        <div class="mb-6">
          <div class="h-10 w-72 bg-gray-200 rounded mb-3"></div>
          <div class="h-5 w-64 bg-gray-200 rounded"></div>
        </div>
        <div class="flex justify-end mb-4 gap-4">
          <div class="h-12 w-44 bg-gray-200 rounded-xl"></div>
          <div class="h-12 w-32 bg-gray-200 rounded-xl"></div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto">
          <div class="flex items-center justify-between mb-6">
            <div class="h-6 w-64 bg-gray-200 rounded"></div>
            <div class="h-9 w-40 bg-gray-200 rounded"></div>
          </div>
          <div class="space-y-3">
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
          </div>
        </div>
      </div>
      </main>
    </div>
  </div>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'peripherals', baseUrl: baseUrl, accessLevel: accessLevel }) %>

      <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden"
        style="min-width: 0; max-width: 100%;">
        <div class="mb-6">
          <h1 style="color: #0F828C;" class="text-4xl font-bold">Peripherals</h1>
          <p style="color: #777777;" class="text-2x1">Peripherals inventory overview</p>
