                  <option value="Mouse">Mouse</option>
                  <option value="Monitor">Monitor</option>
                  <option value="Printer">Printer</option>
                  <option value="Webcam">Webcam</option>
                  <option value="Headset">Headset</option>
                  <option value="Speaker">Speaker</option>
                  <option value="Scanner">Scanner</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="peripheral_pdf" class="block text-sm font-medium text-gray-700 mb-2">Upload PDF</label>
                <input id="peripheral_pdf" name="peripheral_pdf" type="file" accept="application/pdf"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 bg-white focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
