  <script>

    $(document).ready(function () {
      const apiUrl = "<%= baseUrl %>";
      const isAdminUser = JSON.parse('<%- JSON.stringify(!!isAdmin) %>');

      // Page/table skeleton helpers
      const $pageSkeleton = $('#pageSkeleton');
      let initialLoadComplete = false;
      function syncPageSkeletonOffset() {
        const mainEl = document.querySelector('main');
        const contentEl = document.getElementById('pageSkeletonContent');
        if (!mainEl || !contentEl) return;
        const ml = window.getComputedStyle(mainEl).marginLeft;
        contentEl.style.marginLeft = ml;
      }

      function showPageSkeleton() {
        syncPageSkeletonOffset();
        $pageSkeleton.removeClass('hidden');
        $('body').attr('aria-busy', 'true');
      }
      function hidePageSkeleton() {
        $pageSkeleton.addClass('hidden');
        $('body').attr('aria-busy', 'false');
      }

      window.addEventListener('resize', syncPageSkeletonOffset);

      const $peripheralsSkeleton = $('#peripheralsSkeleton');
      const $peripheralsHost = $('#peripheralsTableHost');
      const $peripheralsCard = $('#peripheralsTableCard');
      function showPeripheralsSkeleton() {
        $peripheralsSkeleton.removeClass('hidden');
        $peripheralsHost.addClass('opacity-0');
        $peripheralsCard.attr('aria-busy', 'true');
      }
      function hidePeripheralsSkeleton() {
        $peripheralsSkeleton.addClass('hidden');
        $peripheralsHost.removeClass('opacity-0');
        $peripheralsCard.attr('aria-busy', 'false');
      }

      // Start in loading state until the first DataTables response arrives.
      showPageSkeleton();
      showPeripheralsSkeleton();

      const $peripheralModal = $('#peripheralModal');
      const $inactivePeripheralModal = $('#inactivePeripheralModal');
      const $peripheralForm = $('#peripheralForm');
      let isEditMode = false;
      let editPeripheralId = null;

      // Tom Select instances
      const tsKind = new TomSelect('#kind_of_peripheral', { create: false });
      const tsDept = new TomSelect('#user_dept', { create: false });
      const tsStatus = new TomSelect('#peripheral_status', { create: false });
      const tsLocation = new TomSelect('#peripheral_location', { create: false });
      let tsComputerId;

      // Function to format date to YYYY-MM-DD for HTML date input
      function formatDateForInput(dateString) {
        if (!dateString) return '';
        
        // If already in YYYY-MM-DD format, return as is
        if (/^\d{4}-\d{2}-\d{2}$/.test(dateString)) {
          return dateString;
        }
        
        // Try to parse and format the date
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return ''; // Invalid date
        
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        
        return `${year}-${month}-${day}`;
      }

      // Load computer IDs into dropdown
      $.ajax({
        url:apiUrl + '/computers/getComputerIds',
        method: 'GET',
        dataType: 'json',
        success: function(response) {
          if (response.computerIds) {
            const computerIds = response.computerIds;
            const $computerSelect = $('#computer_id');
            // Clear existing options except the first (placeholder)
            $computerSelect.find('option:not(:first)').remove();
            // Add new options
            computerIds.forEach(id => {
              $computerSelect.append(new Option(id.brand+" "+id.model+" "+id.serial_number, id.computer_id));
            });
          } else {
            console.error('Failed to fetch computer IDs:', response.computerIds);
          }
          // Initialize Tom Select for computer_id after options are loaded
          tsComputerId = new TomSelect('#computer_id', { create: false });
        },
        error: function(xhr, status, error) {
          console.error('Error fetching computer IDs:', error);
        } 
      });

      function openPeripheralModal(editMode = false) {
        isEditMode = editMode;
        if (editMode) {
          $('#peripheralModal h2').text('Edit Peripheral');
          $('#peripheralForm button[type="submit"] span').text('Update Peripheral');
          $('#peripheralForm button[type="submit"] i').removeClass('fa-plus').addClass('fa-save');
        } else {
          // Clear form when opening in Add mode
          $('#peripheralModal h2').text('Peripherals Inventory Form');
          $('#peripheralForm button[type="submit"] span').text('Add Peripheral');
          $('#peripheralForm button[type="submit"] i').removeClass('fa-save').addClass('fa-plus');
          editPeripheralId = null;
          
          // Clear all form fields
          $peripheralForm[0].reset();
          tsKind.clear(); tsKind.setValue('');
          if (tsComputerId) { tsComputerId.clear(); tsComputerId.setValue(''); }
          tsDept.clear(); tsDept.setValue('');
          tsStatus.setValue('active');
          tsLocation.setValue('Floor');
        }
        $peripheralModal.removeClass('hidden');
        $('body').addClass('overflow-hidden');
      }

      function closePeripheralModal() {
        $peripheralModal.addClass('hidden');
        $('body').removeClass('overflow-hidden');
        isEditMode = false;
        editPeripheralId = null;
        
        // Clear form when closing to prevent data leakage to next open
        $peripheralForm[0].reset();
        tsKind.clear(); tsKind.setValue('');
        if (tsComputerId) { tsComputerId.clear(); tsComputerId.setValue(''); }
        tsDept.clear(); tsDept.setValue('');
        tsStatus.setValue('active');
        tsLocation.setValue('Floor');
      }

      function getSelectedPeripheralPdfFile() {
        const input = document.getElementById('peripheral_pdf');
        return input && input.files && input.files.length ? input.files[0] : null;
      }

      function isPdfFile(file) {
        if (!file) return false;
        const nameOk = (file.name || '').toLowerCase().endsWith('.pdf');
        const mimeOk = file.type === 'application/pdf' || file.type === '';
        return nameOk && mimeOk;
      }

      function uploadPeripheralPdf(peripheralId, file) {
        const fd = new FormData();
        fd.append('pdf', file);
        return $.ajax({
          url: apiUrl + '/peripherals/uploadPeripheralPdf/' + encodeURIComponent(peripheralId),
          method: 'POST',
          data: fd,
          processData: false,
          contentType: false
        });
      }

      const peripheralColumns = [
        { data: 'brand' },
        { data: 'model' },
        { data: 'date_of_purchase' },
        { data: 'date_of_entry' },
        { data: 'peripheral_user' },
        { data: 'user_dept' },
        { data: 'kind_of_peripheral' },
        { data: 'serial_no' },
        { data: 'property_tag' },
        { data: 'peripheral_no' },
        { data: 'peripheral_status' },
        { data: 'peripheral_location' }
      ];

      if (isAdminUser) {
        peripheralColumns.push({
          data: 'peripheral_id',
          orderable: false,
          searchable: false,
          render: function (id, type, row) {
            return `
      <div class="flex gap-2">
        <button class="editPeripheralBtn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Edit">
          <i class="fas fa-edit"></i> Edit
        </button>
        <button class="filePeripheralBtn bg-white border-2 border-green-500 text-green-500 hover:bg-green-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Upload File">
          <i class="fas fa-file-upload"></i> File
        </button>
        <button class="deletePeripheralBtn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Delete">
          <i class="fas fa-trash"></i> Delete
        </button>
      </div>
    `;
          }
        });
      }

      const peripheralColumnDefs = [
        { width: '80px', targets: 0 },   // Brand
        { width: '100px', targets: 1 },  // Model
        { width: '110px', targets: 2 },  // Date of Purchase
        { width: '110px', targets: 3 },  // Date of Entry
        { width: '120px', targets: 4 },  // User
        { width: '150px', targets: 5 },  // Department
        { width: '120px', targets: 6 },  // Type of Peripheral
        { width: '120px', targets: 7 },  // Serial No.
        { width: '100px', targets: 8 },  // Property Tag
        { width: '100px', targets: 9 },  // Peripheral No.
        { width: '120px', targets: 10 }, // Peripheral Status
        { width: '120px', targets: 11 }  // Peripheral Location
      ];
      if (isAdminUser) {
        peripheralColumnDefs.push({ width: '100px', targets: 12, className: 'text-center' });
      }

      const peripheralsDt = new DataTable('#peripheralsTable', {
        processing: true,
       serverSide: true,
        ajax: { url: apiUrl+'/peripherals/peripheralDataTable', type:"post", dataType:"json" },
        columns: peripheralColumns,
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        columnDefs: peripheralColumnDefs,
        initComplete: function () {
          hidePeripheralsSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        },
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No data available in table',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
      });

      // Toggle skeleton during server-side DataTables AJAX requests
      if (peripheralsDt && typeof peripheralsDt.on === 'function') {
        peripheralsDt.on('preXhr', function () {
          if (!initialLoadComplete) {
            showPageSkeleton();
          } else {
            showPeripheralsSkeleton();
          }
        });
        peripheralsDt.on('xhr', function () {
          hidePeripheralsSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
        peripheralsDt.on('error', function () {
          hidePeripheralsSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
      }

      let inactivePeripheralDt = null;
      if (isAdminUser) {
        inactivePeripheralDt = new DataTable('#inactivePeripheralTable', {
        processing: true,
        serverSide: true,
        ajax: { url: apiUrl + '/peripherals/inactivePeripheralDataTable', type: 'POST', dataType: 'json' },
        columns: [
          { data: 'brand' },
          { data: 'model' },
          { data: 'peripheral_user' },
          { data: 'peripheral_no' },
          {
            data: 'peripheral_id',
            orderable: false,
            searchable: false,
            render: function (id) {
              return `
                <div class="flex gap-2">
                  <button class="activatePeripheralBtn bg-green-500 border-2 border-green-500 text-white hover:bg-green-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}" title="Activate">
                    <i class="fas fa-check"></i> Activate
                  </button>
                </div>
              `;
            }
          }
        ],
        pageLength: 10,
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        columnDefs: [
          { width: '100px', targets: 0 },
          { width: '100px', targets: 1 },
          { width: '120px', targets: 2 },
          { width: '100px', targets: 3 },
          { width: '120px', targets: 4, className: 'text-center' }
        ],
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No inactive peripherals',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
        });
      }

      $('#openPeripheralModal').on('click', function() {
        // Force clear form before opening in Add mode
        $peripheralForm[0].reset();
        $('#kind_of_peripheral').val('');
        $('#computer_id').val('');
        $('#user_dept').val('');
        $('#peripheral_status').val('active');
        $('#peripheral_location').val('');
        editPeripheralId = null;
        isEditMode = false;
        
        // Then open modal
        openPeripheralModal(false);
      });
      
      $('#closePeripheralModal, #peripheralModalBackdrop').on('click', closePeripheralModal);

      $('#openInactivePeripheralModal').on('click', function() {
        if (!isAdminUser || !inactivePeripheralDt) return;
        $inactivePeripheralModal.removeClass('hidden');
        $('body').addClass('overflow-hidden');
        inactivePeripheralDt.ajax.reload(null, false);
      });

      $('#closeInactivePeripheralModal, #inactivePeripheralModalBackdrop').on('click', function() {
        $inactivePeripheralModal.addClass('hidden');
        $('body').removeClass('overflow-hidden');
      });

      $(document).on('keydown', function (event) {
        if (event.key === 'Escape' && !$peripheralModal.hasClass('hidden')) {
          closePeripheralModal();
        }
        if (event.key === 'Escape' && !$inactivePeripheralModal.hasClass('hidden')) {
          $inactivePeripheralModal.addClass('hidden');
          $('body').removeClass('overflow-hidden');
        }
      });

      $('#clearPeripheralForm').on('click', function () {
        $peripheralForm.trigger('reset');
        $('#kind_of_peripheral').val('');
        $('#computer_id').val('');
        $('#user_dept').val('');
        $('#peripheral_status').val('active');
        $('#peripheral_location').val('');
      });

      // Edit button handler
      $('#peripheralsTable').on('click', '.editPeripheralBtn', function () {
        const id = $(this).data('id');
        editPeripheralId = id;
        
        // Get row data from DataTable
        const rowData = peripheralsDt.row($(this).parents('tr')).data();
        
        console.log('Row data for edit:', rowData); // Debug log
        
        // Populate form fields
        $('#brand').val(rowData.brand || '');
        $('#model').val(rowData.model || '');
        $('#peripheral_no').val(rowData.peripheral_no || '');
        $('#property_tag').val(rowData.property_tag || '');
        $('#serial_no').val(rowData.serial_no || '');
        $('#peripheral_user').val(rowData.peripheral_user || '');
        $('#date_of_purchase').val(formatDateForInput(rowData.date_of_purchase));
        
        // Set dropdown values - add option first if not exists
        if (rowData.kind_of_peripheral) {
          if (!tsKind.getOption(rowData.kind_of_peripheral)) {
            tsKind.addOption({ value: rowData.kind_of_peripheral, text: rowData.kind_of_peripheral });
          }
          tsKind.setValue(rowData.kind_of_peripheral);
        }
        
        if (rowData.computer_id && tsComputerId) {
          if (!tsComputerId.getOption(rowData.computer_id)) {
            tsComputerId.addOption({ value: rowData.computer_id, text: rowData.computer_id });
          }
          tsComputerId.setValue(rowData.computer_id);
        }
        
        if (rowData.user_dept) {
          if (!tsDept.getOption(rowData.user_dept)) {
            tsDept.addOption({ value: rowData.user_dept, text: rowData.user_dept });
          }
          tsDept.setValue(rowData.user_dept);
        }
        
        tsStatus.setValue((rowData.peripheral_status || 'active').toLowerCase());
        
        if (rowData.peripheral_location) {
          if (!tsLocation.getOption(rowData.peripheral_location)) {
            tsLocation.addOption({ value: rowData.peripheral_location, text: rowData.peripheral_location });
          }
          tsLocation.setValue(rowData.peripheral_location);
        }
        
        // Open modal in edit mode
        openPeripheralModal(true);
      });

      // File button handler (preview uploaded PDF)
      $('#peripheralsTable').on('click', '.filePeripheralBtn', function () {
        if (!isAdminUser) return;
        const id = $(this).data('id');

        $.ajax({
          url: apiUrl + '/peripherals/peripheralPdfStatus/' + encodeURIComponent(id),
          method: 'GET',
          dataType: 'json',
          success: function (r) {
            if (r && r.success && r.exists && r.urlPath) {
              const pdfUrl = apiUrl + r.urlPath;
              Swal.fire({
                title: 'Peripheral PDF',
                width: '90vw',
                showCloseButton: true,
                showConfirmButton: false,
                html: `
                  <div style="width:100%;height:75vh;">
                    <iframe src="${pdfUrl}" style="width:100%;height:100%;border:0;" title="Peripheral PDF"></iframe>
                  </div>
                `,
                didOpen: () => {
                  const popup = Swal.getPopup();
                  if (popup) popup.style.maxWidth = '1100px';
                }
              });
            } else {
              Swal.fire({
                icon: 'info',
                title: 'No PDF',
                text: 'No PDF uploaded yet for this peripheral.',
                confirmButtonColor: '#0F828C'
              });
            }
          },
          error: function () {
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: 'Failed to check/view the PDF.',
              confirmButtonColor: '#0F828C'
            });
          }
        });
      });

      $peripheralForm.on('submit', function (event) {
        event.preventDefault();

        if (this.checkValidity && !this.checkValidity()) {
          if (this.reportValidity) this.reportValidity();
          Swal.fire({ icon: 'error', title: 'Missing fields', text: 'Please fill out all required fields.', confirmButtonColor: '#0F828C' });
          return;
        }

        const pdfFile = getSelectedPeripheralPdfFile();
        if (pdfFile && !isPdfFile(pdfFile)) {
          Swal.fire({ icon: 'error', title: 'Invalid file', text: 'PDF files only.', confirmButtonColor: '#0F828C' });
          return;
        }

        // Convert form to object
        const formArray = $(this).serializeArray();
        let data = {};
        formArray.forEach(item => {
          const v = typeof item.value === 'string' ? item.value.trim() : item.value;
          data[item.name] = v === '' ? null : v;
        });

        const isUpdate = isEditMode && editPeripheralId;
        const title = isUpdate ? 'Update Peripheral?' : 'Add Peripheral?';
        const text = isUpdate ? 'Do you want to update this peripheral?' : 'Do you want to add this peripheral?';
        const confirmText = isUpdate ? 'Yes, update it!' : 'Yes, add it!';
        const successTitle = isUpdate ? 'Peripheral Updated' : 'Peripheral Added';
        const apiEndpoint = isUpdate ? apiUrl + '/peripherals/updatePeripheral' : apiUrl + '/peripherals/addPeripheral';

        if (isUpdate) {
          data.peripheral_id = editPeripheralId;
        }

        Swal.fire({
          title,
          text,
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: confirmText,
          cancelButtonText: 'Cancel',
          confirmButtonColor: '#0F828C',
          cancelButtonColor: '#d33'
        }).then((result) => {
          if (!result.isConfirmed) return;

          $.ajax({
            url: apiEndpoint,
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (response) {
              if (!response.success) {
                Swal.fire({ icon: 'error', title: 'Failed', text: response.message || 'Something went wrong.' });
                return;
              }

              const peripheralId = isUpdate ? editPeripheralId : (response.peripheral_id || null);

              const finalize = (extraText) => {
                Swal.fire({
                  icon: 'success',
                  title: successTitle,
                  text: extraText ? `${response.message} ${extraText}` : response.message,
                  confirmButtonColor: '#0F828C'
                });
                $peripheralForm[0].reset();
                tsKind.clear(); tsKind.setValue('');
                if (tsComputerId) { tsComputerId.clear(); tsComputerId.setValue(''); }
                tsDept.clear(); tsDept.setValue('');
                tsStatus.setValue('active');
                tsLocation.setValue('Floor');
                peripheralsDt.ajax.reload(null, false);
                closePeripheralModal();
              };

              if (pdfFile && peripheralId) {
                Swal.fire({ title: 'Uploading PDF...', allowOutsideClick: false, didOpen: () => Swal.showLoading(), confirmButtonColor: '#0F828C' });
                uploadPeripheralPdf(peripheralId, pdfFile)
                  .done(function (uploadRes) {
                    if (uploadRes && uploadRes.success) {
                      finalize('(PDF uploaded)');
                    } else {
                      Swal.fire({ icon: 'error', title: 'Upload failed', text: (uploadRes && uploadRes.message) ? uploadRes.message : 'Failed to upload PDF.', confirmButtonColor: '#0F828C' });
                    }
                  })
                  .fail(function (xhr) {
                    const msg = (xhr && xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : 'Failed to upload PDF.';
                    Swal.fire({ icon: 'error', title: 'Upload failed', text: msg, confirmButtonColor: '#0F828C' });
                  });
              } else {
                finalize('');
              }
            },
            error: function (xhr, status, error) {
              Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred while submitting the form.' });
              console.error(error);
            }
          });
        });
      });


      // SweetAlert delete 
      $('#peripheralsTable').on('click', '.deletePeripheralBtn', function () {
        if (!isAdminUser) return;
        const id = $(this).data('id');
        Swal.fire({
          title: 'Delete?',
          text: `Peripheral ID: ${id}`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonText: 'Yes, delete',
          confirmButtonColor: '#d33',
          cancelButtonColor: '#6c757d'
        }).then((r) => {
          if (r.isConfirmed) {
            $.ajax({
              url: apiUrl + '/peripherals/deletePeripheral',
              method: 'POST',
              contentType: 'application/json',
              data: JSON.stringify({ peripheral_id: id }),
              success: function(response) {
                if (response.success) {
                  Swal.fire({
                    icon: 'success',
                    title: 'Deleted!',
                    text: 'Peripheral has been deleted.',
                    confirmButtonColor: '#0F828C'
                  });
                  peripheralsDt.ajax.reload(null, false);
                  if (inactivePeripheralDt) inactivePeripheralDt.ajax.reload(null, false);
                } else {
                  Swal.fire({
                    icon: 'error',
                    title: 'Failed',
                    text: response.message || 'Failed to delete peripheral.'
                  });
                }
              },
              error: function() {
                Swal.fire({
                  icon: 'error',
                  title: 'Error',
                  text: 'An error occurred while deleting the peripheral.'
                });
              }
            });
          }
        });
      });

      $('#inactivePeripheralTable').on('click', '.activatePeripheralBtn', function () {
        if (!isAdminUser) return;
        const id = $(this).data('id');

        Swal.fire({
          title: 'Activate?',
          text: 'Are you sure you want to activate this peripheral?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: 'Yes, activate',
          confirmButtonColor: '#22c55e',
          cancelButtonColor: '#6c757d',
          cancelButtonText: 'Cancel'
        }).then((result) => {
          if (result.isConfirmed) {
            $.ajax({
              url: apiUrl + '/peripherals/activatePeripheral',
              method: 'POST',
              contentType: 'application/json',
              data: JSON.stringify({ peripheral_id: id }),
              success: function(response) {
                if (response.success) {
                  Swal.fire({
                    icon: 'success',
                    title: 'Activated!',
                    text: 'Peripheral has been activated.',
                    confirmButtonColor: '#22c55e'
                  });
                  if (inactivePeripheralDt) inactivePeripheralDt.ajax.reload(null, false);
                  peripheralsDt.ajax.reload(null, false);
                } else {
                  Swal.fire({
                    icon: 'error',
                    title: 'Failed',
                    text: response.message || 'Failed to activate peripheral.'
                  });
                }
              },
              error: function() {
                Swal.fire({
                  icon: 'error',
                  title: 'Error',
                  text: 'An error occurred while activating the peripheral.'
                });
              }
            });
          }
        });
      });



      // Ensure widths are correct after first layout/paint.
      setTimeout(function () {
        try {
          peripheralsDt.columns.adjust();
        } catch (e) {
          // ignore
        }
      }, 0);
      setTimeout(function () {
        try {
          peripheralsDt.columns.adjust();
        } catch (e) {
          // ignore
        }
      }, 350);

    });
  </script>