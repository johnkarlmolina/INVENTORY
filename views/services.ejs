<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Computer Services - IT Inventory</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://kit.fontawesome.com/ec23f4a8b0.js" crossorigin="anonymous"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- DataTables (Default) -->
  <link href="https://cdn.datatables.net/2.1.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.1.2/js/dataTables.min.js"></script>
  <link rel="icon" type="image/png" href="/Images/ndh-it.png">

  <style>
    /* Hide DataTables' default processing overlay; we use a skeleton loader instead. */
    .dt-processing {
      display: none !important;
    }
  </style>
</head>
<body class="bg-gray-100 overflow-x-hidden">
  <!-- Page Skeleton Loader (initial page/data load) - main content only (keeps sidebar visible) -->
  <div id="pageSkeleton" class="fixed inset-0 z-[60] hidden pointer-events-none">
    <div id="pageSkeletonContent" class="h-full bg-gray-100 overflow-auto">
      <main class="p-8" style="min-width: 0; max-width: 100%;">
      <div class="animate-pulse">
        <div class="mb-6">
          <div class="h-10 w-72 bg-gray-200 rounded mb-3"></div>
          <div class="h-5 w-80 bg-gray-200 rounded"></div>
        </div>
        <div class="flex justify-end mb-4">
          <div class="h-12 w-44 bg-gray-200 rounded-xl"></div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto">
          <div class="flex items-center justify-between mb-6">
            <div class="h-6 w-56 bg-gray-200 rounded"></div>
            <div class="h-9 w-40 bg-gray-200 rounded"></div>
          </div>
          <div class="space-y-3">
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
            <div class="h-10 w-full bg-gray-200 rounded"></div>
          </div>
        </div>
      </div>
      </main>
    </div>
  </div>

  <div class="flex min-h-screen">
    <%- include('partials/sidebar', { page: 'services', baseUrl: baseUrl, accessLevel: accessLevel }) %>
    
    <main class="ml-72 flex-1 p-8 transition-all duration-300 overflow-x-hidden" style="min-width: 0; max-width: 100%;">
      <div class="mb-6">
        <h1 style="color: #0F828C;" class="text-4xl font-bold">Service History</h1>
        <p style="color: #777777;" class="text-2x1">Track computer service requests and repairs</p>
      </div>

      <!-- Button Container -->
      <div class="flex justify-end mb-4">
        <button id="openServiceModal"
          class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
          <i class="fas fa-plus text-lg"></i>
          <span class="font-semibold">Add Service</span>
        </button>
      </div>

      <div class="bg-white rounded-lg shadow-lg p-6 w-full overflow-x-auto relative" id="servicesTableCard" aria-busy="true">
        <!-- Skeleton Loader (shown while DataTables is fetching) -->
        <div id="servicesSkeleton" class="absolute inset-0 z-10 bg-white/80 backdrop-blur-[1px] rounded-lg">
          <div class="p-6 animate-pulse">
            <div class="flex items-center justify-between mb-6">
              <div class="h-6 w-56 bg-gray-200 rounded"></div>
              <div class="h-9 w-40 bg-gray-200 rounded"></div>
            </div>
            <div class="space-y-3">
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
              <div class="h-10 w-full bg-gray-200 rounded"></div>
            </div>
          </div>
        </div>

        <div class="w-full overflow-x-auto opacity-0" id="servicesTableHost">
          <table id="servicesTable" class="display nowrap" style="width:100%">
            <thead style="background-color: #0F828C;">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Service ID</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Serial Number</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Property Tag</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Problem</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Remarks</th>
                <% if (isAdmin) { %>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider whitespace-nowrap">Actions</th>
                <% } %>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Add Service Modal (UI only) -->
  <div id="serviceModal" class="fixed inset-0 z-50 hidden">
    <div id="serviceModalBackdrop" class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 flex min-h-screen items-center justify-center p-4 md:p-6">
      <div class="w-full max-w-4xl max-h-[92vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-gray-200">
        <div class="sticky top-0 z-10 flex items-center justify-between px-6 py-4 border-b border-gray-200 bg-white rounded-t-xl">
          <h2 class="text-2xl font-bold" style="color: #0F828C;">New Service Request</h2>
          <button id="closeServiceModal" type="button"
            class="h-10 w-10 rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#0F828C]"
            aria-label="Close modal">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <form id="serviceForm" class="px-6 py-6" novalidate>
          
          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="type_of_asset" class="block text-sm font-medium text-gray-700 mb-2">Type of asset</label>
                <select id="type_of_asset" name="type_of_asset" 
                    class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="peripheral">Peripheral</option>
                  <option value="computer">Computer</option>
                  <!-- Options will be populated dynamically -->
                </select>
              </div>
              <div>
                <label for="brand_serial" class="block text-sm font-medium text-gray-700 mb-2">Brand/Serial</label>
                <select id="brand_serial" name="brand_serial" 
                    class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
                  <option value="">Select brand/serial</option>
                  <!-- Options will be populated dynamically -->  
                </select>
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="serial_number" class="block text-sm font-medium text-gray-700 mb-2">Serial Number</label>
                <input id="serial_number" name="serial_number" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
              <div>
                <label for="property_tag" class="block text-sm font-medium text-gray-700 mb-2">Property Tag</label>
                <input id="property_tag" name="property_tag" type="text"
                  class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20">
              </div>
            </div>
          </section>

          <section class="mb-6">
            <div>
              <label for="problem" class="block text-sm font-medium text-gray-700 mb-2">Problem Description</label>
                <textarea id="problem" name="problem" rows="4" required
                class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20 resize-none"></textarea>
            </div>
          </section>

          <section class="mb-8">
            <div>
              <label for="remarks" class="block text-sm font-medium text-gray-700 mb-2">Remarks / Solution</label>
              <textarea id="remarks" name="remarks" rows="4"
                class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-[#0F828C] focus:outline-none focus:ring-2 focus:ring-[#0F828C]/20 resize-none"></textarea>
            </div>
          </section>

          <div class="flex items-center gap-4">
            <button type="submit" id="submitServiceForm"
              class="bg-gradient-to-r from-[#0F828C] to-[#2e5558] hover:from-[#2e5558] hover:to-[#0F828C] text-white px-6 py-3 rounded-xl transition-all duration-300 flex items-center gap-3 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-[#0F828C] focus:ring-opacity-50">
              <i class="fas fa-plus text-lg"></i>
              <span class="font-semibold">Submit Service Request</span>
            </button>

            <button id="clearServiceForm" type="button"
              class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-100 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-300">
              Clear Form
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    $(document).ready(function () {
      const apiUrl = "<%= baseUrl %>";
      const isAdminUser = JSON.parse('<%- JSON.stringify(!!isAdmin) %>');

      // Page/table skeleton helpers
      const $pageSkeleton = $('#pageSkeleton');
      let initialLoadComplete = false;
      function syncPageSkeletonOffset() {
        const mainEl = document.querySelector('main');
        const contentEl = document.getElementById('pageSkeletonContent');
        if (!mainEl || !contentEl) return;
        const ml = window.getComputedStyle(mainEl).marginLeft;
        contentEl.style.marginLeft = ml;
      }

      function showPageSkeleton() {
        syncPageSkeletonOffset();
        $pageSkeleton.removeClass('hidden');
        $('body').attr('aria-busy', 'true');
      }
      function hidePageSkeleton() {
        $pageSkeleton.addClass('hidden');
        $('body').attr('aria-busy', 'false');
      }

      window.addEventListener('resize', syncPageSkeletonOffset);

      const $servicesSkeleton = $('#servicesSkeleton');
      const $servicesHost = $('#servicesTableHost');
      const $servicesCard = $('#servicesTableCard');
      function showServicesSkeleton() {
        $servicesSkeleton.removeClass('hidden');
        $servicesHost.addClass('opacity-0');
        $servicesCard.attr('aria-busy', 'true');
      }
      function hideServicesSkeleton() {
        $servicesSkeleton.addClass('hidden');
        $servicesHost.removeClass('opacity-0');
        $servicesCard.attr('aria-busy', 'false');
      }

      // Start in loading state until the first DataTables response arrives.
      showPageSkeleton();
      showServicesSkeleton();

      const serviceColumns = [
        { data: 'service_id' },
        { data: 'serial_number' },
        { data: 'property_tag' },
        { data: 'problem' },
        { data: 'remarks' }
      ];
      if (isAdminUser) {
        serviceColumns.push({
          data: 'service_id',
          orderable: false,
          searchable: false,
          render: function (id) {
            return `
              <div class="inline-flex gap-2 whitespace-nowrap">
                <button class="editServiceBtn bg-white border-2 border-blue-500 text-blue-500 hover:bg-blue-50 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}">
                  <i class="fas fa-edit"></i> Edit
                </button>
                <button class="deleteServiceBtn bg-red-500 border-2 border-red-500 text-white hover:bg-red-600 px-4 py-2 rounded-lg transition-all duration-200" data-id="${id}">
                  <i class="fas fa-trash"></i> Delete
                </button>
              </div>
            `;
          }
        });
      }

      const servicesTable = new DataTable('#servicesTable', {
        processing: true,
        serverSide: true,
        ajax: {
          url: apiUrl + '/services/servicesDataTable',
          type: 'POST',
          dataType: 'json'
        },
        columns: serviceColumns,
        columnDefs: isAdminUser ? [{ width: '170px', targets: 5, className: 'text-center' }] : [],
        pageLength: 10,
        lengthMenu: [10, 25, 50, 100],
        ordering: true,
        searching: true,
        info: true,
        scrollX: true,
        scrollCollapse: true,
        responsive: false,
        autoWidth: false,
        initComplete: function () {
          hideServicesSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        },
        language: {
          search: 'Search:',
          lengthMenu: 'Show _MENU_ entries',
          info: 'Showing _START_ to _END_ of _TOTAL_ entries',
          infoEmpty: 'Showing 0 to 0 of 0 entries',
          infoFiltered: '(filtered from _MAX_ total entries)',
          zeroRecords: 'No matching records found',
          emptyTable: 'No services',
          paginate: { first: 'First', last: 'Last', next: 'Next', previous: 'Previous' }
        }
      });

      // Toggle skeleton during server-side DataTables AJAX requests
      if (servicesTable && typeof servicesTable.on === 'function') {
        servicesTable.on('preXhr', function () {
          if (!initialLoadComplete) {
            showPageSkeleton();
          } else {
            showServicesSkeleton();
          }
        });
        servicesTable.on('xhr', function () {
          hideServicesSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
        servicesTable.on('error', function () {
          hideServicesSkeleton();
          hidePageSkeleton();
          initialLoadComplete = true;
        });
      }

      const $serviceModal = $('#serviceModal');
      const $serviceForm = $('#serviceForm');
      let isEditMode = false;
      let editServiceId = null;

      function openServiceModal() {
        $serviceModal.removeClass('hidden');
        $('body').addClass('overflow-hidden');
      }

      function closeServiceModal() {
        $serviceModal.addClass('hidden');
        $('body').removeClass('overflow-hidden');
        $serviceForm[0].reset();
        isEditMode = false;
        editServiceId = null;
        $('#serviceModal h2').text('New Service Request');
        $('#submitServiceForm span').text('Submit Service Request');
        $('#submitServiceForm i').removeClass('fa-save').addClass('fa-plus');
      }

      function setEditMode(service) {
        isEditMode = true;
        editServiceId = service.service_id;

        $('#serviceModal h2').text('Edit Service Request');
        $('#submitServiceForm span').text('Update Service');
        $('#submitServiceForm i').removeClass('fa-plus').addClass('fa-save');

        $('#serial_number').val(service.serial_number || '');
        $('#property_tag').val(service.property_tag || '');
        $('#problem').val(service.problem || '');
        $('#remarks').val(service.remarks || '');
      }

      $('#openServiceModal').on('click', function () {
        // Add mode
        isEditMode = false;
        editServiceId = null;
        $('#serviceModal h2').text('New Service Request');
        $('#submitServiceForm span').text('Submit Service Request');
        $('#submitServiceForm i').removeClass('fa-save').addClass('fa-plus');
        $serviceForm[0].reset();
        openServiceModal();
      });

      $('#closeServiceModal, #serviceModalBackdrop').on('click', function () {
        closeServiceModal();
      });

      $('#clearServiceForm').on('click', function () {
        $serviceForm[0].reset();
      });

      $serviceForm.on('submit', function (e) {
        e.preventDefault();

        if (this.checkValidity && !this.checkValidity()) {
          if (this.reportValidity) this.reportValidity();
          Swal.fire({ icon: 'error', title: 'Missing fields', text: 'Problem is required.', confirmButtonColor: '#0F828C' });
          return;
        }

        if (!isAdminUser && isEditMode) {
          Swal.fire({ icon: 'error', title: 'Forbidden', text: 'You are not allowed to update services.', confirmButtonColor: '#0F828C' });
          return;
        }

        const payload = {
          serial_number: $('#serial_number').val().trim(),
          property_tag: $('#property_tag').val().trim(),
          problem: $('#problem').val().trim(),
          remarks: $('#remarks').val().trim(),
        };

        if (!payload.serial_number && !payload.property_tag) {
          Swal.fire({ icon: 'error', title: 'Missing fields', text: 'Please provide Serial Number or Property Tag.', confirmButtonColor: '#0F828C' });
          return;
        }

        const url = isEditMode && editServiceId
          ? `${apiUrl}/services/${editServiceId}`
          : `${apiUrl}/services`;
        const method = isEditMode ? 'PUT' : 'POST';

        $.ajax({
          url,
          method,
          contentType: 'application/json',
          data: JSON.stringify(payload),
          success: function (resp) {
            if (!resp || resp.success !== true) {
              Swal.fire({ icon: 'error', title: 'Failed', text: resp?.message || 'Request failed', confirmButtonColor: '#0F828C' });
              return;
            }
            closeServiceModal();
            servicesTable.ajax.reload(null, false);
            Swal.fire({ icon: 'success', title: isEditMode ? 'Updated' : 'Added', text: 'Service saved successfully.', confirmButtonColor: '#0F828C' });
          },
          error: function (xhr) {
            const message = xhr?.responseJSON?.message || 'Request failed';
            Swal.fire({ icon: 'error', title: 'Error', text: message, confirmButtonColor: '#0F828C' });
          }
        });
      });

      // Edit button
      $('#servicesTable').on('click', '.editServiceBtn', function () {
        if (!isAdminUser) return;
        const serviceId = $(this).data('id');
        if (!serviceId) return;

        $.ajax({
          url: `${apiUrl}/services/${serviceId}`,
          method: 'GET',
          success: function (resp) {
            if (!resp || resp.success !== true || !resp.service) {
              Swal.fire({ icon: 'error', title: 'Not found', text: resp?.message || 'Service not found', confirmButtonColor: '#0F828C' });
              return;
            }
            setEditMode(resp.service);
            openServiceModal();
          },
          error: function (xhr) {
            const message = xhr?.responseJSON?.message || 'Failed to load service';
            Swal.fire({ icon: 'error', title: 'Error', text: message, confirmButtonColor: '#0F828C' });
          }
        });
      });

      // Delete button
      $('#servicesTable').on('click', '.deleteServiceBtn', function () {
        if (!isAdminUser) return;
        const serviceId = $(this).data('id');
        if (!serviceId) return;

        Swal.fire({
          icon: 'warning',
          title: 'Delete service?',
          text: 'This action cannot be undone.',
          showCancelButton: true,
          confirmButtonText: 'Delete',
          cancelButtonText: 'Cancel',
          confirmButtonColor: '#d33',
        }).then((result) => {
          if (!result.isConfirmed) return;

          $.ajax({
            url: `${apiUrl}/services/${serviceId}`,
            method: 'DELETE',
            success: function (resp) {
              if (!resp || resp.success !== true) {
                Swal.fire({ icon: 'error', title: 'Failed', text: resp?.message || 'Delete failed', confirmButtonColor: '#0F828C' });
                return;
              }
              servicesTable.ajax.reload(null, false);
              Swal.fire({ icon: 'success', title: 'Deleted', text: 'Service deleted.', confirmButtonColor: '#0F828C' });
            },
            error: function (xhr) {
              const message = xhr?.responseJSON?.message || 'Delete failed';
              Swal.fire({ icon: 'error', title: 'Error', text: message, confirmButtonColor: '#0F828C' });
            }
          });
        });
      });
          $(document).on('change', '#type_of_asset', function() {
            const selectedType = $(this).val();
            const $brandSerialSelect = $('#brand_serial');

            $brandSerialSelect.empty().append('<option value="">Select brand/serial</option>');

            if (selectedType) {
              $.ajax({
                url: apiUrl + `/services/brandSerialOptions`,
                data: { type_of_asset: selectedType },
                method: 'GET',
                success: function(resp) {
                  if (resp && resp.success === true && Array.isArray(resp.options)) {

                    resp.options.forEach(item => {
                      let value = '';
                      let text = '';

                      if (resp.typeAsset === "peripheral") {
                        value = item.peripheral_id;
                        text = `${item.brand} ${item.model} ${item.serial_no} ${item.property_tag}`;
                      } 
                      else if (resp.typeAsset === "computer") {
                        value = item.computer_id;
                        text = `${item.brand} ${item.model} ${item.serial_number} ${item.property_tag}`;
                      }

                      $brandSerialSelect.append(
                        `<option value="${value}">${text}</option>`
                      );
                    });

                  }
                },
                error: function(err) {
                  console.error("AJAX error:", err);
                  alert("Failed to load options");
                }
              });
            }
          });

    });
  </script>
</body>
</html>
